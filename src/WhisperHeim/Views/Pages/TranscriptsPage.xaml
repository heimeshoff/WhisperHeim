<UserControl x:Class="WhisperHeim.Views.Pages.TranscriptsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:WhisperHeim.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <!-- Compact list row -->
        <Style x:Key="CompactRowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="16,10" CornerRadius="8"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Group header toggle button -->
        <Style x:Key="GroupToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Padding="{TemplateBinding Padding}" CornerRadius="6"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status Banner -->
        <Border x:Name="TranscribingBanner"
                Grid.Row="0"
                Visibility="Collapsed"
                Padding="20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF005FAA" Offset="0" />
                    <GradientStop Color="#FF0078D4" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#FF005FAA" Opacity="0.15" BlurRadius="16" ShadowDepth="4" Direction="270" />
            </Border.Effect>
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,12,0" />
                    <TextBlock Text="Transcribing call recording..."
                               Foreground="White"
                               FontSize="13" FontWeight="Medium" />
                    <TextBlock x:Name="QueueCountText"
                               Text=""
                               Foreground="#CCFFFFFF"
                               FontSize="13" FontWeight="Medium" />
                    <TextBlock x:Name="PipelineProgressText"
                               Text=""
                               Foreground="#CCFFFFFF"
                               FontSize="13" FontWeight="Medium"
                               Margin="8,0,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,20,24,16" MaxWidth="900" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Conversations"
                           FontSize="36" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,6" />
                <TextBlock Text="Press Ctrl+Win+R to start or stop a call recording."
                           Style="{StaticResource SubtleText}"
                           Margin="0,0,0,12" />
                <!-- Action buttons: Start/Stop Recording + Browse -->
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="StartStopRecordingButton"
                            Click="StartStopRecording_Click"
                            Padding="16,8" Cursor="Hand"
                            Margin="0,0,10,0"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF005FAA" Offset="0" />
                                            <GradientStop Color="#FF0078D4" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon x:Name="RecordButtonIcon" Symbol="Record24" Foreground="White" Margin="0,0,6,0" FontSize="14" />
                            <TextBlock x:Name="RecordButtonText" Text="Start Recording" Foreground="White"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BrowseFilesButton"
                            Click="BrowseFiles_Click"
                            Padding="16,8" Cursor="Hand"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="FolderOpen24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,6,0" FontSize="14" />
                                        <TextBlock Text="Browse" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Search & Filter Row -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="SearchBox"
                            Grid.Column="0"
                            PlaceholderText="Search transcripts, speakers, or keywords..."
                            TextChanged="SearchBox_TextChanged" />
                <!-- Expand/Collapse All toggle -->
                <Button x:Name="ExpandCollapseAllButton"
                        Grid.Column="2"
                        Click="ExpandCollapseAll_Click"
                        ToolTip="Expand/Collapse All"
                        Padding="10,10" Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                <ui:SymbolIcon Symbol="TextCollapse24"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="16" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="ClearSearchButton"
                        Grid.Column="4"
                        Click="ClearSearch_Click"
                        Padding="16,10" Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Filter24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" FontSize="16" />
                                    <TextBlock Text="FILTERS" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Table header (clickable for sorting) -->
            <Grid Grid.Row="2" Margin="16,0,16,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Tag="Title" Click="ColumnHeader_Click"
                        Background="Transparent" BorderThickness="0" Padding="0,0,12,0" Cursor="Hand">
                    <TextBlock x:Name="TitleSortHeader" Text="TITLE"
                               Style="{StaticResource SectionLabel}" />
                </Button>
                <Button Grid.Column="1" Tag="Speakers" Click="ColumnHeader_Click"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
                    <TextBlock x:Name="SpeakersSortHeader" Text="SPEAKERS"
                               Style="{StaticResource SectionLabel}" />
                </Button>
                <Button Grid.Column="2" Tag="Time" Click="ColumnHeader_Click"
                        Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"
                        HorizontalAlignment="Right">
                    <TextBlock x:Name="TimeSortHeader" Text="TIME &#x2193;"
                               Style="{StaticResource SectionLabel}" />
                </Button>
            </Grid>

            <!-- Compact list with groups -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="GroupedListPanel">
                    <!-- Active recording card -->
                    <Border x:Name="ActiveRecordingCard"
                            Visibility="Collapsed"
                            Margin="0,0,0,12"
                            Padding="16,14"
                            CornerRadius="12"
                            Cursor="Hand"
                            MouseLeftButtonDown="ActiveRecordingCard_Click">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#33FF3B30" Offset="0" />
                                <GradientStop Color="#22FF6B5A" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#44FF3B30" />
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- Pulsing recording indicator -->
                            <Ellipse x:Name="RecordingDot"
                                     Grid.Column="0"
                                     Width="10" Height="10"
                                     Fill="#FFFF3B30"
                                     Margin="0,0,12,0"
                                     VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="ActiveRecordingTitle"
                                           Text="Recording in progress..."
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock x:Name="ActiveRecordingSubtitle"
                                           Text="Click to edit metadata"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                            <TextBlock x:Name="ActiveRecordingDuration"
                                       Grid.Column="2"
                                       Text="00:00"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#FFFF3B30"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Transcribing section (only visible when queue is actively processing) -->
                    <StackPanel x:Name="TranscribingSection" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                            <TextBlock Text="TRANSCRIBING" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                        <ItemsControl x:Name="TranscribingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" Margin="0,1,0,1"
                                            CornerRadius="6"
                                            Background="#1825abfe">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Fill="#FF25abfe"
                                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           TextTrimming="CharacterEllipsis"
                                                           TextWrapping="NoWrap"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Detail}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Foreground="#FF25abfe" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Pending recordings section -->
                    <StackPanel x:Name="PendingSection" Visibility="Collapsed">
                        <ToggleButton IsChecked="True"
                                      Style="{StaticResource GroupToggleButton}"
                                      x:Name="PendingGroupToggle"
                                      Click="GroupToggle_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="PendingGroupChevron" Text="&#xE70D;"
                                           FontFamily="Segoe MDL2 Assets" FontSize="10"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="PENDING" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                                <TextBlock x:Name="PendingCountText" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </ToggleButton>
                        <ItemsControl x:Name="PendingList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource CompactRowButton}"
                                            Click="PendingRow_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Detail}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Transcript groups (populated dynamically) -->
                    <ItemsControl x:Name="TranscriptGroupList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4,0,0">
                                    <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                  Style="{StaticResource GroupToggleButton}"
                                                  Click="TranscriptGroupToggle_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ChevronText}"
                                                       FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding GroupName}" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding CountDisplay}" Style="{StaticResource SectionLabel}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0" />
                                            <TextBlock Text="{Binding SpeakersSummary}"
                                                       Style="{StaticResource SectionLabel}"
                                                       VerticalAlignment="Center"
                                                       Margin="2,0,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="NoWrap"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Visibility="{Binding IsExpanded, Converter={StaticResource InverseBoolToVisibility}}" />
                                        </StackPanel>
                                    </ToggleButton>
                                    <ItemsControl ItemsSource="{Binding Items}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource CompactRowButton}"
                                                        Click="TranscriptRow_Click">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,12,0"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding SpeakersDisplay}"
                                                                   FontSize="11"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding TimeDisplay}"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Right"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyState"
                       Grid.Row="3"
                       Text="No recordings yet. Start a recording or browse for audio files above."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="14"
                       Visibility="Collapsed" />
        </Grid>

        <!-- Detail Drawer -->
        <Border x:Name="DrawerPanel"
                Grid.RowSpan="2"
                HorizontalAlignment="Right"
                Width="520"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                Visibility="Collapsed"
                RenderTransformOrigin="1,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DrawerTranslate" X="520" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="#FF000000" Opacity="0.15" BlurRadius="40" ShadowDepth="-4" Direction="180" />
            </Border.Effect>
            <Grid Margin="28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Drawer header with close button -->
                <DockPanel Grid.Row="0" Margin="0,0,0,12"
                           x:Name="TranscriptDrawerContent">
                    <Button DockPanel.Dock="Right"
                            Click="DrawerClose_Click"
                            VerticalAlignment="Top"
                            Padding="6"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="IconBd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        Background="Transparent">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="16"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="IconBd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <StackPanel>
                        <!-- Recording indicator (visible only during active recording) -->
                        <StackPanel x:Name="RecordingIndicatorPanel" Orientation="Horizontal" Margin="0,0,0,4" Visibility="Collapsed">
                            <Ellipse Width="8" Height="8" Fill="#FFFF3B30" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="RECORDING IN PROGRESS"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="#FFFF3B30" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="DrawerRecordingDuration"
                                   Text="00:00"
                                   FontSize="24" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Visibility="Collapsed"
                                   Margin="0,0,0,6" />
                        <TextBox x:Name="TranscriptNameBox"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 Margin="0,0,0,6"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 LostFocus="TranscriptNameBox_LostFocus"
                                 KeyDown="TranscriptNameBox_KeyDown" />
                        <TextBlock x:Name="TranscriptInfo"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </DockPanel>

                <!-- Audio playback controls -->
                <Border Grid.Row="1"
                        x:Name="PlaybackPanel"
                        Visibility="Collapsed"
                        Padding="14,10"
                        Margin="0,0,0,12"
                        CornerRadius="10"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:Button x:Name="PlayPauseButton"
                                   Grid.Column="0"
                                   Content="Play"
                                   Click="PlayPause_Click"
                                   Padding="10,5"
                                   Margin="0,0,8,0"
                                   FontSize="12" />
                        <ui:Button x:Name="StopButton"
                                   Grid.Column="1"
                                   Content="Stop"
                                   Click="Stop_Click"
                                   Padding="10,5"
                                   Margin="0,0,8,0"
                                   FontSize="12" />
                        <TextBlock x:Name="PlaybackPositionText"
                                   Grid.Column="3"
                                   Text="00:00 / 00:00"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="AudioFileSizeText"
                                   Grid.Column="4"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                        <Button x:Name="DeleteAudioButton"
                                Grid.Column="5"
                                Click="DeleteAudio_Click"
                                Padding="6,4" Cursor="Hand"
                                BorderThickness="0"
                                Margin="8,0,0,0"
                                ToolTip="Delete audio files to reclaim disk space">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                            Background="Transparent">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#FFE74856" Margin="0,0,4,0" FontSize="12" />
                                            <TextBlock Text="DELETE AUDIO" FontSize="9" FontWeight="Bold"
                                                       Foreground="#FFE74856" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#19E74856" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <ui:Button x:Name="OpenExternalButton"
                                   Grid.Column="0" Grid.ColumnSpan="6"
                                   Click="OpenExternal_Click"
                                   Padding="10,5"
                                   FontSize="12"
                                   HorizontalAlignment="Left"
                                   Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Open24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,6,0" FontSize="14" />
                                <TextBlock Text="Open in Player" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </ui:Button>
                    </Grid>
                </Border>

                <!-- Speaker names panel -->
                <Border Grid.Row="2"
                        x:Name="SpeakerNamesPanel"
                        Visibility="Collapsed"
                        Padding="14,10"
                        Margin="0,0,0,12"
                        CornerRadius="10"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="SPEAKER NAMES"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button x:Name="AddSpeakerButton"
                                        Content="+ Add"
                                        Click="AddSpeaker_Click"
                                        Padding="8,3" FontSize="11"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#FF005FAA" Cursor="Hand" />
                                <Button x:Name="ReTranscribeButton"
                                        Click="ReTranscribe_Click"
                                        Padding="10,4" Cursor="Hand"
                                        Margin="8,0,0,0"
                                        BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                    Background="#19005FAA">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="ArrowSync24" Foreground="#FF005FAA" Margin="0,0,4,0" FontSize="12" />
                                                    <TextBlock Text="RE-TRANSCRIBE" FontSize="9" FontWeight="Bold"
                                                               Foreground="#FF005FAA" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#33005FAA" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                        <ItemsControl x:Name="SpeakerNamesList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2">
                                        <Button Content="x"
                                                Click="RemoveSpeaker_Click"
                                                DockPanel.Dock="Right"
                                                Padding="4,1" FontSize="10"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                Cursor="Hand"
                                                VerticalAlignment="Center" />
                                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 FontSize="12"
                                                 Padding="6,3"
                                                 BorderThickness="1"
                                                 KeyDown="SpeakerNameList_KeyDown"
                                                 LostFocus="SpeakerName_LostFocus" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Recording info text (visible only during active recording) -->
                <TextBlock x:Name="RecordingInfoText"
                           Grid.Row="2"
                           Text="Speaker names will be used for transcription when the recording stops."
                           FontSize="11"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           VerticalAlignment="Bottom"
                           Visibility="Collapsed" />

                <!-- Transcript content -->
                <ScrollViewer Grid.Row="3"
                              VerticalScrollBarVisibility="Auto"
                              x:Name="TranscriptScrollViewer">
                    <ItemsControl x:Name="SegmentList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,6,0,6"
                                        Padding="16,12"
                                        CornerRadius="12"
                                        Background="{Binding CurrentBackground}"
                                        Cursor="{Binding SegmentCursor}"
                                        MouseLeftButtonDown="Segment_MouseLeftButtonDown">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding DisplaySpeaker}"
                                                       FontWeight="Bold"
                                                       FontSize="11"
                                                       Foreground="{Binding SpeakerColor}"
                                                       Cursor="Hand"
                                                       ToolTip="Click to rename speaker; Shift+Click to rename just this segment"
                                                       MouseLeftButtonDown="SpeakerLabel_MouseLeftButtonDown"
                                                       Visibility="{Binding IsEditingSpeaker, Converter={StaticResource InverseBoolToVisibility}}" />
                                            <!-- Speaker name edit: ComboBox with editable text -->
                                            <ComboBox IsEditable="True"
                                                      Text="{Binding EditingSpeakerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding AvailableSpeakerNames}"
                                                      FontWeight="Bold"
                                                      FontSize="11"
                                                      MinWidth="120"
                                                      Padding="2,0"
                                                      Visibility="{Binding IsEditingSpeaker, Converter={StaticResource BoolToVisibility}}"
                                                      PreviewMouseLeftButtonDown="SpeakerComboBox_PreviewMouseLeftButtonDown"
                                                      SelectionChanged="SpeakerComboBox_SelectionChanged"
                                                      LostFocus="SpeakerEditBox_LostFocus"
                                                      KeyDown="SpeakerEditBox_KeyDown"
                                                      Loaded="SpeakerEditBox_Loaded" />
                                            <TextBlock Text="{Binding TimestampDisplay}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Text="  playing"
                                                       FontSize="10"
                                                       Foreground="#FF005FAA"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsCurrentlyPlaying, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Text}"
                                                   TextWrapping="Wrap"
                                                   FontSize="13"
                                                   LineHeight="20"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Placeholder -->
                <TextBlock x:Name="PlaceholderText"
                           Grid.Row="3"
                           Text="Select a transcript to view"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           FontSize="14"
                           Visibility="Collapsed" />

                <!-- Analysis Results Panel -->
                <Border Grid.Row="4"
                        x:Name="AnalysisPanel"
                        Visibility="Collapsed"
                        Padding="14,10"
                        Margin="0,0,0,8"
                        CornerRadius="10"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MaxHeight="300" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <!-- Header -->
                        <DockPanel Grid.Row="0" Margin="0,0,0,8">
                            <Button Click="CloseAnalysis_Click"
                                    DockPanel.Dock="Right"
                                    Padding="4" Cursor="Hand"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTip="Close">
                                <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Button>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="BrainCircuit24" Foreground="#FF005FAA" Margin="0,0,6,0" FontSize="14" />
                                <TextBlock x:Name="AnalysisTitleText"
                                           Text="Analysis"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DockPanel>
                        <!-- Scrollable result -->
                        <ScrollViewer Grid.Row="1" x:Name="AnalysisScrollViewer"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="AnalysisResultText"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       LineHeight="20"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </ScrollViewer>
                        <!-- Status / actions -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock x:Name="AnalysisStatusText"
                                       Text="Analyzing..."
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <Button x:Name="StopAnalysisButton"
                                    Content="Stop"
                                    Click="StopAnalysis_Click"
                                    Padding="8,3" FontSize="11"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#FFE74856" Cursor="Hand"
                                    Visibility="Collapsed" />
                            <Button x:Name="CopyAnalysisButton"
                                    Content="Copy"
                                    Click="CopyAnalysis_Click"
                                    Padding="8,3" FontSize="11"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#FF005FAA" Cursor="Hand"
                                    Visibility="Collapsed" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <Border Grid.Row="5"
                        Padding="0,12,0,0"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0"
                        x:Name="ActionPanel"
                        Visibility="Collapsed">
                    <DockPanel>
                        <!-- Delete on the left -->
                        <Button Click="DrawerDeleteTranscript_Click"
                                DockPanel.Dock="Left"
                                Padding="10,8" Cursor="Hand"
                                BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                            Background="Transparent">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#FFE74856" Margin="0,0,6,0" FontSize="14" />
                                            <TextBlock Text="DELETE" FontSize="10" FontWeight="Bold"
                                                       Foreground="#FFE74856" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#19E74856" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Export actions on the right -->
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Right"
                                    HorizontalAlignment="Right">
                            <!-- Analyze button -->
                            <Button Click="AnalyzeButton_Click"
                                    Margin="0,0,8,0" Padding="14,8" Cursor="Hand"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                Background="#19005FAA">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="BrainCircuit24" Foreground="#FF005FAA" Margin="0,0,6,0" FontSize="14" />
                                                <TextBlock Text="ANALYZE" FontSize="10" FontWeight="Bold"
                                                           Foreground="#FF005FAA" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#33005FAA" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Click="CopyToClipboard_Click"
                                    Margin="0,0,8,0" Padding="14,8" Cursor="Hand"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Copy24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,6,0" FontSize="14" />
                                                <TextBlock Text="COPY" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock x:Name="CopiedIndicator"
                                       Text="Copied!"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF0078D4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Visibility="Collapsed" />
                            <Button Click="ExportMarkdown_Click"
                                    Margin="0,0,8,0" Padding="14,8" Cursor="Hand"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ArrowDownload24" Foreground="White" Margin="0,0,6,0" FontSize="14" />
                                                <TextBlock Text="MD" FontSize="10" FontWeight="Bold"
                                                           Foreground="White" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="JSON" Click="ExportJson_Click"
                                    Margin="0,0,0,0" Padding="10,8"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Cursor="Hand" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
