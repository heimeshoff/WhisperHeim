<UserControl x:Class="WhisperHeim.Views.Pages.TranscriptsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:converters="clr-namespace:WhisperHeim.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status Banner -->
        <Border x:Name="TranscribingBanner"
                Grid.Row="0"
                Visibility="Collapsed"
                Padding="20,12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF005FAA" Offset="0" />
                    <GradientStop Color="#FF0078D4" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#FF005FAA" Opacity="0.15" BlurRadius="16" ShadowDepth="4" Direction="270" />
            </Border.Effect>
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,12,0" />
                    <TextBlock Text="Transcribing call recording..."
                               Foreground="White"
                               FontSize="13" FontWeight="Medium" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="24,20,24,16" MaxWidth="900" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Recordings"
                           FontSize="36" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,6" />
                <TextBlock Text="Press Ctrl+Win+R to start or stop a call recording."
                           Style="{StaticResource SubtleText}" />
            </StackPanel>

            <!-- Search & Filter Row -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="SearchBox"
                            Grid.Column="0"
                            PlaceholderText="Search transcripts, speakers, or keywords..."
                            TextChanged="SearchBox_TextChanged" />
                <Button x:Name="ClearSearchButton"
                        Grid.Column="2"
                        Click="ClearSearch_Click"
                        Padding="16,10" Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Filter24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,8,0" FontSize="16" />
                                    <TextBlock Text="FILTERS" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Split: list + viewer -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" MinWidth="160" MaxWidth="280" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Transcript list -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="RECENT TRANSCRIPTS"
                               Style="{StaticResource SectionLabel}"
                               Margin="8,0,0,12" />

                    <ListBox x:Name="TranscriptList"
                             Grid.Row="1"
                             SelectionChanged="TranscriptList_SelectionChanged"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,3" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" CornerRadius="12" Padding="16,14"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                        <Condition Property="IsSelected" Value="False" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="ItemRoot" ClipToBounds="True">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,4">
                                            <TextBlock Text="{Binding DateDisplay}"
                                                       FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                       TextWrapping="NoWrap"
                                                       VerticalAlignment="Top" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       TextWrapping="NoWrap"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding DurationDisplay}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding PreviewText}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <!-- Hover trash icon -->
                                    <Button x:Name="DeleteItemButton"
                                            Click="DeleteTranscriptItem_Click"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,-4,-2"
                                            Padding="4"
                                            Cursor="Hand"
                                            Visibility="Hidden"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ToolTip="Delete transcript">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="IconBd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ui:SymbolIcon Symbol="Delete24" FontSize="14"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="IconBd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DeleteItemButton"
                                                                                   Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                                                Value="{x:Static Visibility.Visible}" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DeleteItemButton"
                                                                                   Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                                                Value="{x:Static Visibility.Hidden}" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- RIGHT: Transcript viewer -->
                <Border Grid.Column="2"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF005FAA" Opacity="0.04" BlurRadius="32" ShadowDepth="8" Direction="270" />
                    </Border.Effect>
                    <Grid Margin="28,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Viewer header -->
                        <StackPanel Grid.Row="0" x:Name="ViewerHeader" Visibility="Collapsed">
                            <TextBox x:Name="TranscriptNameBox"
                                     FontSize="18"
                                     FontWeight="Bold"
                                     Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                     Margin="0,0,0,6"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     LostFocus="TranscriptNameBox_LostFocus"
                                     KeyDown="TranscriptNameBox_KeyDown" />
                            <TextBlock x:Name="TranscriptInfo"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,16" />
                        </StackPanel>

                        <!-- Audio playback controls -->
                        <Border Grid.Row="1"
                                x:Name="PlaybackPanel"
                                Visibility="Collapsed"
                                Padding="14,10"
                                Margin="0,0,0,12"
                                CornerRadius="10"
                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:Button x:Name="PlayPauseButton"
                                           Grid.Column="0"
                                           Content="Play"
                                           Click="PlayPause_Click"
                                           Padding="10,5"
                                           Margin="0,0,8,0"
                                           FontSize="12" />
                                <ui:Button x:Name="StopButton"
                                           Grid.Column="1"
                                           Content="Stop"
                                           Click="Stop_Click"
                                           Padding="10,5"
                                           Margin="0,0,8,0"
                                           FontSize="12" />
                                <TextBlock x:Name="PlaybackPositionText"
                                           Grid.Column="3"
                                           Text="00:00 / 00:00"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Transcript content -->
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      x:Name="TranscriptScrollViewer">
                            <ItemsControl x:Name="SegmentList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,6,0,6"
                                                Padding="16,12"
                                                CornerRadius="12"
                                                Background="{Binding CurrentBackground}"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="Segment_MouseLeftButtonDown">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding DisplaySpeaker}"
                                                               FontWeight="Bold"
                                                               FontSize="11"
                                                               Foreground="{Binding SpeakerColor}"
                                                               Cursor="Hand"
                                                               ToolTip="Click to rename speaker; Shift+Click to rename just this segment"
                                                               MouseLeftButtonDown="SpeakerLabel_MouseLeftButtonDown"
                                                               Visibility="{Binding IsEditingSpeaker, Converter={StaticResource InverseBoolToVisibility}}" />
                                                    <TextBox Text="{Binding EditingSpeakerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             FontWeight="Bold"
                                                             FontSize="11"
                                                             MinWidth="80"
                                                             Padding="2,0"
                                                             BorderThickness="1"
                                                             Visibility="{Binding IsEditingSpeaker, Converter={StaticResource BoolToVisibility}}"
                                                             LostFocus="SpeakerEditBox_LostFocus"
                                                             KeyDown="SpeakerEditBox_KeyDown"
                                                             Loaded="SpeakerEditBox_Loaded" />
                                                    <TextBlock Text="{Binding TimestampDisplay}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="  playing"
                                                               FontSize="10"
                                                               Foreground="#FF005FAA"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IsCurrentlyPlaying, Converter={StaticResource BoolToVisibility}}" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap"
                                                           FontSize="13"
                                                           LineHeight="20"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Placeholder -->
                        <TextBlock x:Name="PlaceholderText"
                                   Grid.Row="2"
                                   Text="Select a transcript to view"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   FontSize="14" />

                        <!-- Action buttons -->
                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    Margin="0,16,0,0"
                                    x:Name="ActionPanel"
                                    Visibility="Collapsed">
                            <Button Click="CopyToClipboard_Click"
                                    Margin="0,0,8,0" Padding="14,8" Cursor="Hand"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                                Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Copy24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,6,0" FontSize="14" />
                                                <TextBlock Text="COPY" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <TextBlock x:Name="CopiedIndicator"
                                       Text="Copied!"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#FF0078D4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Visibility="Collapsed" />
                            <Button Click="ExportMarkdown_Click"
                                    Margin="0,0,8,0" Padding="14,8" Cursor="Hand"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ArrowDownload24" Foreground="White" Margin="0,0,6,0" FontSize="14" />
                                                <TextBlock Text="MD" FontSize="10" FontWeight="Bold"
                                                           Foreground="White" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="JSON" Click="ExportJson_Click"
                                    Margin="0,0,8,0" Padding="10,8"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="11" Cursor="Hand" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
