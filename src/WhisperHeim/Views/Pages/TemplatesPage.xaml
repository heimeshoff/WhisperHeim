<UserControl x:Class="WhisperHeim.Views.Pages.TemplatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <!-- Gradient CTA button -->
        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF005FAA" Opacity="0.2" BlurRadius="16" ShadowDepth="4" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="160" MaxWidth="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT: Master Template List ═══════ -->
        <Border Grid.Column="0" Background="{DynamicResource LayerFillColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="12,20,12,12">
                    <TextBlock Text="Templates"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               Margin="0,0,0,16" />
                    <ui:TextBox x:Name="SearchBox"
                                PlaceholderText="Search templates..."
                                TextChanged="SearchBox_TextChanged" />
                </StackPanel>

                <ListBox x:Name="TemplateList"
                         Grid.Row="1"
                         Margin="6,0,6,8"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="TemplateList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" CornerRadius="8" Padding="10,8"
                                                Background="Transparent">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#FF005FAA" />
                                                <Setter TargetName="Bd" Property="BorderThickness" Value="4,0,0,0" />
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True" />
                                                    <Condition Property="IsSelected" Value="False" />
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="32"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══════ RIGHT: Detail / Edit Area ═══════ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
            <StackPanel Margin="40,36,40,32" MaxWidth="640">
                <!-- Header -->
                <TextBlock Text="Edit Template"
                           FontSize="30" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,6" />
                <TextBlock Text="Craft reusable snippets for your voice dictations."
                           Style="{StaticResource SubtleText}"
                           Margin="0,0,0,28" />

                <!-- Template Name -->
                <TextBlock Text="TEMPLATE NAME"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,0,0,8" />
                <ui:TextBox x:Name="NameTextBox"
                            PlaceholderText="Template trigger name (e.g. 'greeting')"
                            Margin="0,0,0,24" />

                <!-- Template Body -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="TEMPLATE BODY"
                               Style="{StaticResource SectionLabel}"
                               DockPanel.Dock="Left" VerticalAlignment="Center" />
                    <!-- Placeholder tag pills -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Border Background="#FFD3E3FF" CornerRadius="12" Padding="10,5" Margin="4,0">
                            <TextBlock Text="{}{date}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                        </Border>
                        <Border Background="#FFD3E3FF" CornerRadius="12" Padding="10,5" Margin="4,0">
                            <TextBlock Text="{}{time}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                        </Border>
                    </StackPanel>
                </DockPanel>
                <ui:TextBox x:Name="TextTextBox"
                            AcceptsReturn="True"
                            MinHeight="200"
                            MaxHeight="360"
                            PlaceholderText="Template text. Use {date}, {time} for placeholders."
                            Margin="0,0,0,32" />

                <!-- Action Footer -->
                <Border Padding="0,20,0,0"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <Button x:Name="DeleteButton"
                                Content="Delete Template"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#FFBA1A1A" FontWeight="Medium"
                                Padding="12,8" Cursor="Hand"
                                IsEnabled="False"
                                Click="DeleteButton_Click"
                                DockPanel.Dock="Left" />
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Right"
                                    HorizontalAlignment="Right">
                            <Button x:Name="AddButton"
                                    Margin="0,0,12,0"
                                    Click="AddButton_Click"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontWeight="Medium"
                                    Padding="20,10" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                Add New
                            </Button>
                            <Button x:Name="UpdateButton"
                                    Style="{StaticResource GradientButton}"
                                    IsEnabled="False"
                                    Click="UpdateButton_Click">
                                <TextBlock Text="Update Template" Foreground="White" />
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- New Template gradient card -->
                <Border Margin="0,40,0,0" CornerRadius="16" Padding="24"
                        Cursor="Hand" HorizontalAlignment="Right">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF0078D4" Offset="0" />
                            <GradientStop Color="#FF1565C0" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Add24" Foreground="White" FontSize="28"
                                      HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="NEW TEMPLATE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
