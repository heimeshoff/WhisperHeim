<UserControl x:Class="WhisperHeim.Views.Pages.TemplatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <!-- Gradient CTA button -->
        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF005FAA" Opacity="0.2" BlurRadius="16" ShadowDepth="4" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Compact list row style -->
        <Style x:Key="CompactRowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="16,10" CornerRadius="8"
                                Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Content -->
        <Grid Margin="24,20,24,16" MaxWidth="900" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Templates"
                           FontSize="36" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,6" />
                <TextBlock Text="Craft reusable snippets for your voice dictations. Hold Ctrl+Win+Alt and speak a template name."
                           Style="{StaticResource SubtleText}" />
            </StackPanel>

            <!-- Search + Add button -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="SearchBox"
                            Grid.Column="0"
                            PlaceholderText="Search templates..."
                            TextChanged="SearchBox_TextChanged" />
                <Button x:Name="AddNewButton"
                        Grid.Column="2"
                        Click="AddNewButton_Click"
                        Padding="16,10" Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FF005FAA" Offset="0" />
                                        <GradientStop Color="#FF0078D4" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add24" Foreground="White" Margin="0,0,6,0" FontSize="14" />
                                    <TextBlock Text="ADD NEW" FontSize="10" FontWeight="Bold"
                                               Foreground="White" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Table header -->
            <Grid Grid.Row="2" Margin="16,0,16,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="NAME"
                           Style="{StaticResource SectionLabel}" />
                <TextBlock Grid.Column="1" Text="DESCRIPTION"
                           Style="{StaticResource SectionLabel}" />
            </Grid>

            <!-- Compact list -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TemplateList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource CompactRowButton}"
                                    Click="TemplateRow_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Text}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyState"
                       Grid.Row="3"
                       Text="No templates yet. Click Add New to create one."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="14"
                       Visibility="Collapsed" />
        </Grid>

        <!-- Drawer overlay (click-away background) -->
        <Border x:Name="DrawerOverlay"
                Background="#33000000"
                Visibility="Collapsed"
                MouseLeftButtonDown="DrawerOverlay_Click" />

        <!-- Detail Drawer -->
        <Border x:Name="DrawerPanel"
                HorizontalAlignment="Right"
                Width="440"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                Visibility="Collapsed"
                RenderTransformOrigin="1,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="DrawerTranslate" X="440" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="#FF000000" Opacity="0.15" BlurRadius="40" ShadowDepth="-4" Direction="180" />
            </Border.Effect>
            <Grid Margin="28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Drawer header with close button -->
                <DockPanel Grid.Row="0" Margin="0,0,0,20">
                    <Button x:Name="DrawerCloseButton"
                            DockPanel.Dock="Right"
                            Click="DrawerClose_Click"
                            VerticalAlignment="Top"
                            Padding="6"
                            Cursor="Hand"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip="Close">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="IconBd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        Background="Transparent">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="16"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="IconBd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock x:Name="DrawerTitle"
                               Text="Edit Template"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>

                <!-- Drawer body -->
                <StackPanel Grid.Row="1">
                    <!-- Template Name -->
                    <TextBlock Text="TEMPLATE NAME"
                               Style="{StaticResource SectionLabel}"
                               Margin="0,0,0,8" />
                    <ui:TextBox x:Name="NameTextBox"
                                PlaceholderText="Template trigger name (e.g. 'greeting')"
                                Margin="0,0,0,24" />

                    <!-- Template Body -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="TEMPLATE BODY"
                                   Style="{StaticResource SectionLabel}"
                                   DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <!-- Placeholder tag pills -->
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <Border Background="#FFD3E3FF" CornerRadius="12" Padding="10,5" Margin="4,0">
                                <TextBlock Text="{}{date}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                            </Border>
                            <Border Background="#FFD3E3FF" CornerRadius="12" Padding="10,5" Margin="4,0">
                                <TextBlock Text="{}{time}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                            </Border>
                        </StackPanel>
                    </DockPanel>
                    <ui:TextBox x:Name="TextTextBox"
                                AcceptsReturn="True"
                                MinHeight="200"
                                MaxHeight="360"
                                PlaceholderText="Template text. Use {date}, {time} for placeholders."
                                Margin="0,0,0,32" />
                </StackPanel>

                <!-- Action Footer -->
                <Border Grid.Row="2"
                        Padding="0,20,0,0"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <!-- Delete button on the left -->
                        <Button x:Name="DrawerDeleteButton"
                                DockPanel.Dock="Left"
                                Click="DrawerDelete_Click"
                                Padding="10,8" Cursor="Hand"
                                BorderThickness="0"
                                Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                            Background="Transparent">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#FFE74856" Margin="0,0,6,0" FontSize="14" />
                                            <TextBlock Text="DELETE" FontSize="10" FontWeight="Bold"
                                                       Foreground="#FFE74856" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#19E74856" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Save button on the right -->
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Right"
                                    HorizontalAlignment="Right">
                            <Button x:Name="SaveButton"
                                    Style="{StaticResource GradientButton}"
                                    Click="SaveButton_Click">
                                <TextBlock x:Name="SaveButtonText" Text="Save Template" Foreground="White" />
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
