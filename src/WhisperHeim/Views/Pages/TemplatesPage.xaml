<UserControl x:Class="WhisperHeim.Views.Pages.TemplatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF404752" />
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FF404752" />

        </Style>
        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="20,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF005FAA" Opacity="0.2" BlurRadius="12" ShadowDepth="3" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FFF3F3F3">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT: Template Master List ═══════ -->
        <Border Grid.Column="0" Background="#80F9F9F9"
                BorderBrush="#19C0C7D4" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,24,20,16">
                    <TextBlock Text="Templates"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#FF1A1C1C"
                               Margin="0,0,0,12" />
                    <ui:TextBox x:Name="SearchBox"
                                PlaceholderText="Search templates..."
                                TextChanged="SearchBox_TextChanged" />
                </StackPanel>

                <ListBox x:Name="TemplateList"
                         Grid.Row="1"
                         Margin="8,0,8,8"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="TemplateList_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" CornerRadius="12" Margin="0,2">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="#FF1A1C1C" />
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="#FF404752"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="220"
                                               HorizontalAlignment="Left"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══════ RIGHT: Detail / Edit Area ═══════ -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,32,32,24" MaxWidth="600">
                <TextBlock Text="Edit Template"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#FF1A1C1C"
                           Margin="0,0,0,4" />
                <TextBlock Text="Craft reusable snippets for your voice dictations."
                           Style="{StaticResource SubtleText}"
                           Margin="0,0,0,24" />

                <!-- Template Name -->
                <TextBlock Text="TEMPLATE NAME"
                           Style="{StaticResource SectionLabel}"
                           Margin="0,0,0,8" />
                <ui:TextBox x:Name="NameTextBox"
                            PlaceholderText="Template trigger name (e.g. 'greeting')"
                            Margin="0,0,0,20" />

                <!-- Template Body -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="TEMPLATE BODY"
                               Style="{StaticResource SectionLabel}"
                               DockPanel.Dock="Left" VerticalAlignment="Center" />
                    <!-- Placeholder tag buttons -->
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Border Background="#FFD3E3FF" CornerRadius="12" Padding="8,4" Margin="4,0">
                            <TextBlock Text="{}{date}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                        </Border>
                        <Border Background="#FFD3E3FF" CornerRadius="12" Padding="8,4" Margin="4,0">
                            <TextBlock Text="{}{time}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                        </Border>
                        <Border Background="#FFD3E3FF" CornerRadius="12" Padding="8,4" Margin="4,0">
                            <TextBlock Text="{}{clipboard}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                        </Border>
                    </StackPanel>
                </DockPanel>
                <ui:TextBox x:Name="TextTextBox"
                            AcceptsReturn="True"
                            MinHeight="160"
                            MaxHeight="300"
                            PlaceholderText="Template text. Use {date}, {time}, {clipboard} for placeholders."
                            Margin="0,0,0,24" />

                <!-- Action Footer -->
                <Border Padding="0,16,0,0"
                        BorderBrush="#19C0C7D4" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <ui:Button x:Name="DeleteButton"
                                   Content="Delete Template"
                                   Appearance="Danger"
                                   IsEnabled="False"
                                   Click="DeleteButton_Click"
                                   DockPanel.Dock="Left" />
                        <StackPanel Orientation="Horizontal"
                                    DockPanel.Dock="Right"
                                    HorizontalAlignment="Right">
                            <ui:Button x:Name="AddButton"
                                       Content="Add New"
                                       Margin="0,0,8,0"
                                       Click="AddButton_Click" />
                            <Button x:Name="UpdateButton"
                                    Style="{StaticResource GradientButton}"
                                    IsEnabled="False"
                                    Click="UpdateButton_Click">
                                <TextBlock Text="Update Template" Foreground="White" />
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
