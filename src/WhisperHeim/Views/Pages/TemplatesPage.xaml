<UserControl x:Class="WhisperHeim.Views.Pages.TemplatesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <!-- Gradient CTA button -->
        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="24,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF005FAA" Opacity="0.2" BlurRadius="16" ShadowDepth="4" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Content -->
        <Grid Margin="24,20,24,16" MaxWidth="900" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Templates"
                           FontSize="36" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,6" />
                <TextBlock Text="Craft reusable snippets for your voice dictations. Hold Ctrl+Win+Alt and speak a template name."
                           Style="{StaticResource SubtleText}" />
            </StackPanel>

            <!-- Search -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <ui:TextBox x:Name="SearchBox"
                            PlaceholderText="Search templates..."
                            TextChanged="SearchBox_TextChanged" />
            </Grid>

            <!-- Split: list + editor -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" MinWidth="160" MaxWidth="280" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Template list -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="TEMPLATES"
                               Style="{StaticResource SectionLabel}"
                               Margin="8,0,0,12" />

                    <ListBox x:Name="TemplateList"
                             Grid.Row="1"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="TemplateList_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,3" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" CornerRadius="12" Padding="16,14"
                                                    ClipToBounds="True"
                                                    Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True" />
                                                        <Condition Property="IsSelected" Value="False" />
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid x:Name="ItemRoot" ClipToBounds="True">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   TextWrapping="NoWrap"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Text}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="10"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextWrapping="NoWrap"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                    <!-- Hover trash icon -->
                                    <Button x:Name="DeleteItemButton"
                                            Click="DeleteTemplateItem_Click"
                                            VerticalAlignment="Bottom"
                                            HorizontalAlignment="Right"
                                            Margin="0,0,-4,-2"
                                            Padding="4"
                                            Cursor="Hand"
                                            Visibility="Hidden"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            ToolTip="Delete template">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="IconBd" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                                        Background="Transparent">
                                                    <ui:SymbolIcon Symbol="Delete24" FontSize="14"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="IconBd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DeleteItemButton"
                                                                                   Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                                                Value="{x:Static Visibility.Visible}" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DeleteItemButton"
                                                                                   Storyboard.TargetProperty="Visibility">
                                                        <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                                                Value="{x:Static Visibility.Hidden}" />
                                                    </ObjectAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- RIGHT: Detail / Edit Area -->
                <Border Grid.Column="2"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF005FAA" Opacity="0.04" BlurRadius="32" ShadowDepth="8" Direction="270" />
                    </Border.Effect>
                    <StackPanel Margin="28,24">
                        <!-- Template Name -->
                        <TextBlock Text="TEMPLATE NAME"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,8" />
                        <ui:TextBox x:Name="NameTextBox"
                                    PlaceholderText="Template trigger name (e.g. 'greeting')"
                                    Margin="0,0,0,24" />

                        <!-- Template Body -->
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="TEMPLATE BODY"
                                       Style="{StaticResource SectionLabel}"
                                       DockPanel.Dock="Left" VerticalAlignment="Center" />
                            <!-- Placeholder tag pills -->
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Border Background="#FFD3E3FF" CornerRadius="12" Padding="10,5" Margin="4,0">
                                    <TextBlock Text="{}{date}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                                </Border>
                                <Border Background="#FFD3E3FF" CornerRadius="12" Padding="10,5" Margin="4,0">
                                    <TextBlock Text="{}{time}" FontSize="10" FontWeight="SemiBold" Foreground="#FF004883" />
                                </Border>
                            </StackPanel>
                        </DockPanel>
                        <ui:TextBox x:Name="TextTextBox"
                                    AcceptsReturn="True"
                                    MinHeight="200"
                                    MaxHeight="360"
                                    PlaceholderText="Template text. Use {date}, {time} for placeholders."
                                    Margin="0,0,0,32" />

                        <!-- Action Footer -->
                        <Border Padding="0,20,0,0"
                                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal"
                                            DockPanel.Dock="Right"
                                            HorizontalAlignment="Right">
                                    <Button x:Name="AddButton"
                                            Margin="0,0,12,0"
                                            Click="AddButton_Click"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" FontWeight="Medium"
                                            Padding="20,10" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}"
                                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        Add New
                                    </Button>
                                    <Button x:Name="UpdateButton"
                                            Style="{StaticResource GradientButton}"
                                            IsEnabled="False"
                                            Click="UpdateButton_Click">
                                        <TextBlock Text="Update Template" Foreground="White" />
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
