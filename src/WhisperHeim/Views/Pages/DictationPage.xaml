<UserControl x:Class="WhisperHeim.Views.Pages.DictationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             SizeChanged="Page_SizeChanged">
    <UserControl.Resources>
        <!-- Quiet Engine: Subtle body text -->
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
            <Setter Property="LineHeight" Value="20" />
        </Style>
        <!-- Quiet Engine: Section label — 10px uppercase bold tracking -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <!-- Quiet Engine: Kbd pill key cap -->
        <Style x:Key="KbdPill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
        </Style>
        <Style x:Key="KbdText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource ApplicationBackgroundBrush}">
        <Grid Margin="40,36,40,32" MaxWidth="900" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══════ Header Section (Branding) ═══════ -->
            <StackPanel Grid.Row="0" Margin="0,0,0,32">
                <!-- Logo with blue border -->
                <Border Width="88" Height="88"
                        CornerRadius="18" Margin="0,0,0,20"
                        HorizontalAlignment="Left"
                        BorderThickness="3"
                        BorderBrush="#FF25abfe"
                        Background="#1025abfe">
                    <Viewbox Margin="12">
                        <Canvas Width="24" Height="24">
                            <!-- Microphone head (capsule) - Blue -->
                            <Path Fill="#FF25abfe"
                                  Data="M12,2 C9.79,2 8,3.79 8,6 L8,12 C8,14.21 9.79,16 12,16 C14.21,16 16,14.21 16,12 L16,6 C16,3.79 14.21,2 12,2 Z" />
                            <!-- Microphone stand (arc + stem + base) - Orange -->
                            <Path Fill="#FFff8b00"
                                  Data="M6,11 L6,12 C6,15.31 8.69,18 12,18 C15.31,18 18,15.31 18,12 L18,11 L16.5,11 L16.5,12 C16.5,14.49 14.49,16.5 12,16.5 C9.51,16.5 7.5,14.49 7.5,12 L7.5,11 Z M11.25,18.5 L11.25,21 L8.5,21 L8.5,22.5 L15.5,22.5 L15.5,21 L12.75,21 L12.75,18.5 Z" />
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- App name + version -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="WhisperHeim"
                               FontSize="40" FontWeight="ExtraBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="v1.0"
                               FontSize="18" FontWeight="Medium"
                               Foreground="#66005FAA"
                               VerticalAlignment="Top"
                               Margin="8,8,0,0" />
                </StackPanel>

                <TextBlock Text="Transform your voice into text locally and securely. Experience near-instant transcription with zero data leakage."
                           Style="{StaticResource SubtleText}"
                           TextWrapping="Wrap"
                           MaxWidth="520"
                           HorizontalAlignment="Left" />
            </StackPanel>

            <!-- ═══════ Audio Input Device Row ═══════ -->
            <Grid x:Name="AudioInputRow" Grid.Row="1" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="AudioInputCol" Width="*" />
                    <ColumnDefinition x:Name="AudioInputGapCol" Width="24" />
                    <ColumnDefinition x:Name="AudioInputWarningCol" Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="AudioInputStackedWarningRow" Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Microphone Selector Card -->
                <Border Grid.Column="0" Grid.Row="0" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="AUDIO INPUT DEVICE"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,16" />
                        <ComboBox x:Name="MicrophoneCombo"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="MicrophoneCombo_SelectionChanged" />
                    </StackPanel>
                </Border>

                <!-- Device Warning Card (only shows when device missing) -->
                <Border x:Name="DeviceWarningCard" Grid.Column="2" Grid.Row="0"
                        Background="#FFFFDBC8" CornerRadius="12" Padding="24"
                        Visibility="Collapsed" MinWidth="280">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" Foreground="#FF974700" Margin="0,0,12,0"
                                       VerticalAlignment="Top" />
                        <StackPanel>
                            <TextBlock Text="Action Required"
                                       FontSize="13" FontWeight="Bold"
                                       Foreground="#FF311300"
                                       Margin="0,0,0,4" />
                            <TextBlock x:Name="DeviceWarning"
                                       FontSize="13" Foreground="#DD311300"
                                       TextWrapping="Wrap"
                                       LineHeight="20" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════ Bento Grid (8-col + 4-col) ═══════ -->
            <Grid x:Name="BentoGrid" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="BentoLeftCol" Width="8*" />
                    <ColumnDefinition x:Name="BentoGapCol" Width="24" />
                    <ColumnDefinition x:Name="BentoRightCol" Width="4*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="BentoStackedRow" Height="Auto" />
                </Grid.RowDefinitions>

                <!-- LEFT: Transcription Canvas -->
                <StackPanel x:Name="TranscriptionPanel" Grid.Column="0" Grid.Row="0">
                    <!-- Transcription text area with watermark -->
                    <Grid Margin="0,0,0,12">
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="0">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF005FAA" Opacity="0.02" BlurRadius="24" ShadowDepth="4" Direction="270" />
                            </Border.Effect>
                            <TextBox x:Name="TestTextBox"
                                     MinHeight="280"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="18"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="28,24"
                                     Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="12" />
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </Border>
                        <!-- Watermark (visible when TextBox is empty) -->
                        <TextBlock x:Name="WatermarkText"
                                   Text="Click the text box and press Ctrl+Win to start dictation. Your transcription appears as you speak."
                                   FontSize="16" Foreground="{DynamicResource TextFillColorDisabledBrush}"
                                   IsHitTestVisible="False"
                                   Margin="28,24,28,0"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Top" />
                    </Grid>

                    <!-- Copy / Clear buttons below the text area -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="CopyButton" FontSize="11"
                                Background="Transparent" BorderThickness="0"
                                Padding="10,6" Margin="4,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Click="CopyButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Copy24" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Copy" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ClearButton" FontSize="11"
                                Background="Transparent" BorderThickness="0"
                                Padding="10,6" Margin="4,0"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Click="ClearButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Delete24" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Clear" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- RIGHT: Sidebar Cards -->
                <StackPanel x:Name="HotkeysPanel" Grid.Column="2" Grid.Row="0">
                    <!-- Hotkeys Card -->
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="28">
                        <Border.Effect>
                            <DropShadowEffect Color="#FF005FAA" Opacity="0.06" BlurRadius="32" ShadowDepth="8" Direction="270" />
                        </Border.Effect>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <ui:SymbolIcon Symbol="Keyboard24" Foreground="#FF005FAA" Margin="0,0,10,0" />
                                <TextBlock Text="HOTKEYS"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            </StackPanel>

                            <!-- Shortcut: Dictation -->
                            <DockPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Win" Style="{StaticResource KbdText}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Dictation" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>

                            <!-- Shortcut: Read Aloud -->
                            <DockPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Win" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="^" Style="{StaticResource KbdText}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Read Aloud" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>

                            <!-- Shortcut: Template Dictation -->
                            <DockPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Win" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Alt" Style="{StaticResource KbdText}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Template Dictation" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>

                            <!-- Shortcut: Call Recording -->
                            <DockPanel Margin="0,0,0,14">
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Ctrl" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="Win" Style="{StaticResource KbdText}" />
                                    </Border>
                                    <Border Style="{StaticResource KbdPill}">
                                        <TextBlock Text="R" Style="{StaticResource KbdText}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="Call Recording" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>

                            <!-- Footer note -->
                            <Border Margin="0,12,0,0" Padding="0,16,0,0"
                                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                                <TextBlock Text="Global hotkeys work even when WhisperHeim is minimized to the system tray."
                                           FontSize="10" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" LineHeight="16" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
