<UserControl x:Class="WhisperHeim.Views.Pages.VoiceCloningPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel Margin="24">
        <TextBlock Text="Voice Cloning"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <!-- Warning about audio quality -->
        <Border Background="#33FFA500"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24"
                               Foreground="Orange"
                               Margin="0,0,8,0" />
                <TextBlock TextWrapping="Wrap"
                           Foreground="Orange"
                           FontSize="12">
                    <Run FontWeight="SemiBold">Audio quality matters.</Run>
                    <Run>Record in a quiet environment with minimal background noise. Use a good microphone, speak clearly, and keep a consistent distance. Minimum 5 seconds of audio is required; 10-15 seconds produces better results.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Voice Name -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Voice Name" FontWeight="Medium" />
                    <TextBlock Text="Enter a name for this voice clone"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <TextBox x:Name="VoiceNameTextBox"
                     MinWidth="220"
                     MaxLength="50"
                     TextChanged="VoiceNameTextBox_TextChanged" />
        </ui:CardControl>

        <!-- Device Selection -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Microphone" FontWeight="Medium" />
                    <TextBlock Text="Select the audio input device for recording"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="MicrophoneCombo"
                      MinWidth="220" />
        </ui:CardControl>

        <!-- Recording Controls -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Record Voice Sample" FontWeight="Medium" />
                    <TextBlock Text="Press Start to record your voice sample (44.1kHz high quality)"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="RecordButton"
                        Content="Start Recording"
                        Click="RecordButton_Click"
                        Margin="0,0,8,0" />
                <Button x:Name="StopButton"
                        Content="Stop"
                        Click="StopButton_Click"
                        IsEnabled="False" />
            </StackPanel>
        </ui:CardControl>

        <!-- Audio Level Meter -->
        <TextBlock Text="Audio Level"
                   FontSize="13"
                   FontWeight="Medium"
                   Margin="0,8,0,4" />
        <Grid Height="24" Margin="0,0,0,4">
            <Border Background="#22FFFFFF"
                    CornerRadius="4" />
            <Border x:Name="LevelMeterFill"
                    Background="#FF4CAF50"
                    CornerRadius="4"
                    HorizontalAlignment="Left"
                    Width="0" />
        </Grid>

        <!-- Duration Display -->
        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
            <TextBlock x:Name="DurationText"
                       Text="Duration: 0.0s"
                       FontSize="14"
                       FontWeight="Medium"
                       Margin="0,0,12,0" />
            <TextBlock x:Name="MinimumIndicator"
                       Text="(minimum 5s required)"
                       FontSize="12"
                       Foreground="Gray"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Progress bar for minimum duration -->
        <Grid Height="4" Margin="0,0,0,16">
            <Border Background="#22FFFFFF"
                    CornerRadius="2" />
            <Border x:Name="MinDurationProgress"
                    CornerRadius="2"
                    HorizontalAlignment="Left"
                    Width="0">
                <Border.Background>
                    <SolidColorBrush x:Name="MinDurationBrush" Color="#FF4CAF50" />
                </Border.Background>
            </Border>
        </Grid>

        <!-- Save Button -->
        <Button x:Name="SaveButton"
                Content="Save Voice"
                Click="SaveButton_Click"
                IsEnabled="False"
                HorizontalAlignment="Left"
                Padding="24,8"
                FontWeight="Medium" />

        <!-- Status -->
        <TextBlock x:Name="StatusText"
                   FontSize="12"
                   Opacity="0.7"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />

        <!-- Existing Custom Voices -->
        <TextBlock Text="Custom Voices"
                   FontSize="16"
                   FontWeight="Medium"
                   Margin="0,24,0,8" />
        <TextBlock x:Name="NoVoicesText"
                   Text="No custom voices yet. Record a voice sample above to create one."
                   Opacity="0.5"
                   FontSize="12"
                   Margin="0,0,0,8" />
        <ItemsControl x:Name="VoicesList" />
    </StackPanel>
</UserControl>
