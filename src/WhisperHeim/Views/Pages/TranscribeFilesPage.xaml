<UserControl x:Class="WhisperHeim.Views.Pages.TranscribeFilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             AllowDrop="True"
             Drop="OnDrop"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             DragOver="OnDragOver">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Transcribe Files"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <!-- Drop Zone -->
        <Border x:Name="DropZone"
                Grid.Row="1"
                MinHeight="120"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="2"
                CornerRadius="8"
                Background="Transparent"
                Margin="0,0,0,16">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDragOver, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="16">
                <ui:SymbolIcon Symbol="ArrowDownload24"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                <TextBlock Text="Drag and drop audio files here"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           Margin="0,0,0,4" />
                <TextBlock Text="Supported: .ogg, .mp3, .m4a, .wav"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           Opacity="0.6"
                           Margin="0,0,0,12" />
                <ui:Button x:Name="PickFilesButton"
                           Content="Browse files..."
                           Appearance="Primary"
                           HorizontalAlignment="Center"
                           Click="OnPickFilesClick" />
            </StackPanel>
        </Border>

        <!-- Results List -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ResultsList"
                          ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardControl Margin="0,0,0,8">
                            <ui:CardControl.Header>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- File name and status -->
                                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding FileName}"
                                                   FontWeight="Medium"
                                                   DockPanel.Dock="Left"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding StatusText}"
                                                   DockPanel.Dock="Right"
                                                   HorizontalAlignment="Right"
                                                   Opacity="0.6"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>

                                    <!-- Progress bar (visible during transcription) -->
                                    <ProgressBar Grid.Row="1"
                                                 Value="{Binding Progress}"
                                                 Maximum="100"
                                                 Height="4"
                                                 Margin="0,0,0,4"
                                                 Visibility="{Binding IsTranscribing, Converter={StaticResource BoolToVisibility}}" />

                                    <!-- Transcript text -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding TranscriptText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"
                                               Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}" />

                                    <!-- Duration and copy button -->
                                    <DockPanel Grid.Row="3"
                                               Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="{Binding DurationText}"
                                                   DockPanel.Dock="Left"
                                                   Opacity="0.6"
                                                   FontSize="12"
                                                   VerticalAlignment="Center" />
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <ui:Button Content="Copy"
                                                       Appearance="Secondary"
                                                       Click="OnCopyClick"
                                                       Tag="{Binding}"
                                                       Margin="0,0,4,0" />
                                            <ui:Button Content="Save"
                                                       Appearance="Secondary"
                                                       Click="OnSaveClick"
                                                       Tag="{Binding}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Error text -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding ErrorText}"
                                               Foreground="Red"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </ui:CardControl.Header>
                        </ui:CardControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>
</UserControl>
