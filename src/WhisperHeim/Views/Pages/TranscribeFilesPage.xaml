<UserControl x:Class="WhisperHeim.Views.Pages.TranscribeFilesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             AllowDrop="True"
             Drop="OnDrop"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             DragOver="OnDragOver">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#FF404752" />
        </Style>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FF404752" />

        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFF9F9F9">
        <StackPanel Margin="32,32,32,24" MaxWidth="800"
                    HorizontalAlignment="Left">
            <!-- Header -->
            <TextBlock Text="Transcriptions"
                       FontSize="28" FontWeight="Bold"
                       Foreground="#FF1A1C1C"
                       Margin="0,0,0,4" />
            <TextBlock Text="Convert your audio and video recordings into text locally. Your data never leaves this machine."
                       Style="{StaticResource SubtleText}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,32" />

            <!-- Drop Zone with glow effect -->
            <Border x:Name="DropZone"
                    MinHeight="160"
                    CornerRadius="12"
                    Background="#FFF3F3F3"
                    BorderBrush="#80C0C7D4"
                    BorderThickness="2"
                    Margin="0,0,0,24">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDragOver, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="BorderBrush" Value="#FF005FAA" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="24">
                    <Border Width="56" Height="56"
                            CornerRadius="28"
                            Background="#FFD3E3FF"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="ArrowDownload24"
                                       FontSize="24"
                                       Foreground="#FF005FAA"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Drop audio or video files here"
                               HorizontalAlignment="Center"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="#FF1A1C1C"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Supported formats: OGG, MP3, M4A, WAV"
                               HorizontalAlignment="Center"
                               Style="{StaticResource SubtleText}"
                               Margin="0,0,0,16" />
                    <Button x:Name="PickFilesButton"
                            Click="OnPickFilesClick"
                            HorizontalAlignment="Center"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="24,10"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="12" Padding="{TemplateBinding Padding}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF005FAA" Offset="0" />
                                            <GradientStop Color="#FF0078D4" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FF005FAA" Opacity="0.2" BlurRadius="16" ShadowDepth="4" />
                                    </Border.Effect>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Add24" Foreground="White" Margin="0,0,6,0" />
                                        <TextBlock Text="Browse Files" Foreground="White" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Results Header -->
            <TextBlock Text="RECENT TRANSCRIPTIONS"
                       Style="{StaticResource SectionLabel}"
                       Margin="0,0,0,12" />

            <!-- Results List -->
            <ItemsControl x:Name="ResultsList"
                          ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFFFF"
                                CornerRadius="12"
                                Padding="20"
                                Margin="0,0,0,12"
                                BorderBrush="#19C0C7D4"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- File name and status -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding FileName}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               DockPanel.Dock="Left"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding StatusText}"
                                               DockPanel.Dock="Right"
                                               HorizontalAlignment="Right"
                                               Foreground="#FF404752"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                </DockPanel>

                                <!-- Progress bar -->
                                <Grid Grid.Row="1" Height="4" Margin="0,0,0,8"
                                      Visibility="{Binding IsTranscribing, Converter={StaticResource BoolToVisibility}}">
                                    <Border Background="#FFE8E8E8" CornerRadius="2" />
                                    <Border CornerRadius="2" HorizontalAlignment="Left"
                                            Width="{Binding Progress}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FF005FAA" Offset="0" />
                                                <GradientStop Color="#FF0078D4" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>

                                <!-- Transcript text -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding TranscriptText}"
                                           TextWrapping="Wrap"
                                           FontSize="13"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}" />

                                <!-- Duration and buttons -->
                                <DockPanel Grid.Row="3"
                                           Visibility="{Binding HasResult, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="{Binding DurationText}"
                                               DockPanel.Dock="Left"
                                               Foreground="#FF404752"
                                               FontSize="12"
                                               VerticalAlignment="Center" />
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <ui:Button Content="Copy"
                                                   Appearance="Secondary"
                                                   Click="OnCopyClick"
                                                   Tag="{Binding}"
                                                   Margin="0,0,4,0" />
                                        <ui:Button Content="Save"
                                                   Appearance="Secondary"
                                                   Click="OnSaveClick"
                                                   Tag="{Binding}" />
                                    </StackPanel>
                                </DockPanel>

                                <!-- Error text -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding ErrorText}"
                                           Foreground="#FFBA1A1A"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
