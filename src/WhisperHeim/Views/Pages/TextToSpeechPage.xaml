<UserControl x:Class="WhisperHeim.Views.Pages.TextToSpeechPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <UserControl.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FF005FAA" />
        </Style>
        <Style x:Key="SubtleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="GradientButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="28,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF005FAA" Offset="0" />
                                    <GradientStop Color="#FF0078D4" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF005FAA" Opacity="0.2" BlurRadius="20" ShadowDepth="6" Direction="270" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SourceToggleButton" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="6" Padding="12,6"
                                Background="Transparent" Cursor="Hand">
                            <TextBlock x:Name="Txt"
                                       Text="{TemplateBinding Content}"
                                       FontSize="11" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
                                <Setter TargetName="Txt" Property="Foreground" Value="#FF005FAA" />
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#20000000" BlurRadius="4" ShadowDepth="1" Opacity="0.15" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}">
        <Grid Margin="40,36,40,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="8*" MinWidth="300" />
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="4*" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <!-- ═══════════════ LEFT: Input Workspace (8-col bento) ═══════════════ -->
            <StackPanel Grid.Column="0">
                <!-- Page Header -->
                <TextBlock Text="Text to Speech"
                           FontSize="30" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,6" />
                <TextBlock Text="Synthesize lifelike speech using local neural models."
                           Style="{StaticResource SubtleText}"
                           Margin="0,0,0,28" />

                <!-- Main TTS Card -->
                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="28" Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect Color="#FF005FAA" Opacity="0.04" BlurRadius="32" ShadowDepth="8" Direction="270" />
                    </Border.Effect>
                    <StackPanel>
                        <!-- Header row: label + voice selector -->
                        <DockPanel Margin="0,0,0,20">
                            <TextBlock Text="INPUT WORKSPACE"
                                       Style="{StaticResource SectionLabel}"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right"
                                        HorizontalAlignment="Right">
                                <ui:SymbolIcon Symbol="Person24"
                                               Margin="0,0,8,0"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ComboBox x:Name="VoiceCombo"
                                          MinWidth="180"
                                          SelectionChanged="VoiceCombo_SelectionChanged" />
                            </StackPanel>
                        </DockPanel>

                        <!-- Text Input -->
                        <TextBox x:Name="SpeechTextInput"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="200"
                                 MaxHeight="360"
                                 Background="{DynamicResource ControlFillColorDefaultBrush}"
                                 BorderThickness="0"
                                 Padding="20"
                                 FontSize="15"
                                 Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                 TextChanged="SpeechTextInput_TextChanged">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="12" />
                                </Style>
                            </TextBox.Resources>
                        </TextBox>

                        <!-- Playback Progress -->
                        <StackPanel Margin="0,20,0,0">
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="SYNTHESIS BUFFER"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           DockPanel.Dock="Left" />
                                <TextBlock x:Name="PlaybackTimeText"
                                           Text="Ready"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" />
                            </DockPanel>
                            <Grid Height="4">
                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="2" />
                                <ProgressBar x:Name="GenerationProgress"
                                             Height="4"
                                             IsIndeterminate="True"
                                             Visibility="Collapsed" />
                            </Grid>
                        </StackPanel>

                        <!-- Controls Row -->
                        <Border Margin="0,24,0,0" Padding="0,20,0,0"
                                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                    <Button x:Name="PlayButton"
                                            Click="PlayButton_Click"
                                            IsEnabled="False"
                                            Width="48" Height="48" Padding="0"
                                            ToolTip="Play">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="24"
                                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}" Width="48" Height="48"
                                                        Cursor="Hand">
                                                    <ui:SymbolIcon Symbol="Play24"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFD3E3FF" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="StopButton"
                                            Click="StopButton_Click"
                                            IsEnabled="False"
                                            Width="48" Height="48" Padding="0" Margin="10,0,0,0"
                                            ToolTip="Stop">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" CornerRadius="24"
                                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}" Width="48" Height="48"
                                                        Cursor="Hand">
                                                    <ui:SymbolIcon Symbol="Stop24"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFFFDAD6" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                                <Button x:Name="SaveAsButton"
                                        Style="{StaticResource GradientButton}"
                                        Click="SaveAsButton_Click"
                                        IsEnabled="False"
                                        HorizontalAlignment="Right"
                                        DockPanel.Dock="Right">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,8,0" Foreground="White" />
                                        <TextBlock Text="Save Audio" Foreground="White" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Status Summary Cards -->
                <UniformGrid Columns="3" Margin="0,0,0,0">
                    <Border Background="{DynamicResource SubtleFillColorTertiaryBrush}" CornerRadius="12" Padding="16" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="MODEL" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="ModelInfoText" Text="Pocket TTS"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,6,0,0"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SubtleFillColorTertiaryBrush}" CornerRadius="12" Padding="16" Margin="4,0,4,0">
                        <StackPanel>
                            <TextBlock Text="INFERENCE" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="InferenceText" Text="--"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,6,0,0"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource SubtleFillColorTertiaryBrush}" CornerRadius="12" Padding="16" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="OUTPUT" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock Text="24kHz / WAV"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,6,0,0"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Status Text -->
                <TextBlock x:Name="StatusText"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="0,14,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- ═══════════════ RIGHT: Voice Clone Sidebar (4-col) ═══════════════ -->
            <StackPanel Grid.Column="2">
                <!-- Clone New Voice Card -->
                <Border Background="{DynamicResource ApplicationBackgroundBrush}" CornerRadius="12" Padding="20"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Ellipse Width="8" Height="8" Fill="#FFBA1A1A" Margin="0,0,10,0" />
                            <TextBlock Text="CLONE NEW VOICE"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        </StackPanel>

                        <!-- Source Toggle: Microphone / System Audio -->
                        <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="8" Padding="3" Margin="0,0,0,14">
                            <UniformGrid Columns="2">
                                <RadioButton x:Name="MicSourceToggle"
                                             Content="MICROPHONE"
                                             IsChecked="True"
                                             Style="{StaticResource SourceToggleButton}"
                                             GroupName="CloneSource"
                                             Checked="SourceToggle_Changed" />
                                <RadioButton x:Name="SystemAudioToggle"
                                             Content="SYSTEM AUDIO"
                                             Style="{StaticResource SourceToggleButton}"
                                             GroupName="CloneSource"
                                             Checked="SourceToggle_Changed" />
                            </UniformGrid>
                        </Border>

                        <!-- Device selector -->
                        <ComboBox x:Name="CloneDeviceCombo"
                                  Margin="0,0,0,14"
                                  HorizontalAlignment="Stretch" />

                        <!-- Audio Visualizer -->
                        <Border Background="{DynamicResource SubtleFillColorTertiaryBrush}" CornerRadius="10" Height="80" Margin="0,0,0,14">
                            <Grid x:Name="LevelMeterGrid">
                                <Border x:Name="LevelMeterFill"
                                        Background="#40005FAA"
                                        CornerRadius="10"
                                        HorizontalAlignment="Left"
                                        Width="0" />
                                <TextBlock x:Name="LevelText"
                                           Text="--"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Recording Progress -->
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="PROGRESS (MIN 5S)"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       DockPanel.Dock="Left" />
                            <TextBlock x:Name="CloneDurationText"
                                       Text="00:00"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#FFBA1A1A"
                                       DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" />
                        </DockPanel>
                        <Grid Height="4" Margin="0,0,0,14">
                            <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="2" />
                            <Border x:Name="CloneDurationProgress"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left"
                                    Width="0">
                                <Border.Background>
                                    <SolidColorBrush x:Name="CloneDurationBrush" Color="#FF4CAF50" />
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- Record / Stop buttons -->
                        <DockPanel Margin="0,0,0,10">
                            <Button x:Name="CloneRecordButton"
                                    Content="Record"
                                    Click="CloneRecordButton_Click"
                                    Padding="14,7"
                                    DockPanel.Dock="Left" />
                            <Button x:Name="CloneStopButton"
                                    Content="Stop"
                                    Click="CloneStopButton_Click"
                                    IsEnabled="False"
                                    Padding="14,7"
                                    Margin="8,0,0,0"
                                    DockPanel.Dock="Left" />
                        </DockPanel>

                        <!-- Voice Name + Save -->
                        <TextBox x:Name="CloneVoiceNameBox"
                                 MaxLength="50"
                                 Margin="0,0,0,10"
                                 TextChanged="CloneVoiceNameBox_TextChanged" />
                        <Button x:Name="CloneSaveButton"
                                Click="CloneSaveButton_Click"
                                IsEnabled="False"
                                HorizontalAlignment="Stretch"
                                Padding="14,10"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                            Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                        <TextBlock Text="SAVE VOICE INSTANCE"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   HorizontalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Clone status -->
                        <TextBlock x:Name="CloneStatusText"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Library Voices -->
                <TextBlock Text="LIBRARY VOICES"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Margin="4,0,0,12" />
                <ItemsControl x:Name="VoicesList" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
