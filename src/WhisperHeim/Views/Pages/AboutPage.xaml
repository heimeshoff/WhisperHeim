<UserControl x:Class="WhisperHeim.Views.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource ApplicationBackgroundBrush}">
        <StackPanel Margin="40,36,40,32" MaxWidth="800"
                    HorizontalAlignment="Left">

            <!-- ═══════ Hero Section ═══════ -->
            <StackPanel HorizontalAlignment="Center" Margin="0,20,0,48">
                <!-- Logo with gradient border -->
                <Border Width="88" Height="88"
                        CornerRadius="18" Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        Padding="3">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF005FAA" Offset="0" />
                            <GradientStop Color="#FF0078D4" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="14">
                        <ui:SymbolIcon Symbol="Mic24" FontSize="36"
                                       Foreground="#FF005FAA"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                    </Border>
                </Border>

                <!-- App name + version -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="WhisperHeim"
                               FontSize="40" FontWeight="ExtraBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock Text="v0.1.0"
                               FontSize="18" FontWeight="Medium"
                               Foreground="#66005FAA"
                               VerticalAlignment="Top"
                               Margin="8,8,0,0" />
                </StackPanel>

                <TextBlock Text="High-fidelity local transcription powered by the quiet engine of modern neural networks."
                           FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="460" />
            </StackPanel>

            <!-- ═══════ Bento Grid: Philosophy + Models ═══════ -->
            <Grid Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="5*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="7*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: Philosophy card -->
                <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="28">
                    <StackPanel>
                        <TextBlock Text="PHILOSOPHY"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16" />
                        <TextBlock Text="Ethereal Precision."
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="WhisperHeim was designed to bridge the gap between technical utility and digital sanctuary. No data leaves your machine, ensuring absolute privacy without sacrificing performance."
                                   FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="19"
                                   Margin="0,0,0,24" />
                        <TextBlock Text="ARCHITECTURE"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Real Core + GPU"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,0,16,0" />
                            <ui:SymbolIcon Symbol="Flash24" Foreground="#FF005FAA" FontSize="18" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- RIGHT: AI Models card -->
                <Border Grid.Column="2" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="12" Padding="0">
                    <StackPanel>
                        <DockPanel Margin="24,24,24,16">
                            <TextBlock Text="AI MODELS"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left" />
                            <Border Background="#FFD3E3FF" CornerRadius="8" Padding="10,4"
                                    DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <TextBlock Text="STATUS" FontSize="9" FontWeight="Bold"
                                           Foreground="#FF004883" />
                            </Border>
                        </DockPanel>

                        <!-- Model list -->
                        <ItemsControl x:Name="ModelList" Margin="12,0,12,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="10"
                                            Padding="16,14"
                                            Margin="0,3,0,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Status icon -->
                                            <Border Grid.Column="0"
                                                    Width="36" Height="36"
                                                    CornerRadius="8"
                                                    Margin="0,0,14,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#19005FAA" />
                                                </Border.Background>
                                                <ui:SymbolIcon Symbol="Checkmark24"
                                                               Foreground="{Binding StatusBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name and description -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Size and status -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <Border Background="{DynamicResource SubtleFillColorSecondaryBrush}" CornerRadius="6" Padding="10,4"
                                                        HorizontalAlignment="Right" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding SizeText}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                </Border>
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="10"
                                                           Foreground="{Binding StatusBrush}"
                                                           FontWeight="Medium"
                                                           HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════ Bottom Info Row ═══════ -->
            <UniformGrid Columns="2" Margin="0,0,0,0">
                <Border Background="{DynamicResource SubtleFillColorTertiaryBrush}" CornerRadius="12" Padding="20" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="PLATFORM" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBlock Text="Universal Windows App"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="WPF / .NET 8 / Local Compute"
                                   FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource SubtleFillColorTertiaryBrush}" CornerRadius="12" Padding="20" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="LICENSE" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,6" />
                        <TextBlock Text="MIT License"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="Open Source / Local-First"
                                   FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
