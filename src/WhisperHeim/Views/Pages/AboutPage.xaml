<UserControl x:Class="WhisperHeim.Views.Pages.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#FFF9F9F9">
        <StackPanel Margin="32,32,32,24" MaxWidth="700"
                    HorizontalAlignment="Left">
            <!-- Hero Section -->
            <StackPanel HorizontalAlignment="Center" Margin="0,24,0,48">
                <Border Width="80" Height="80"
                        CornerRadius="16" Margin="0,0,0,16"
                        HorizontalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF005FAA" Offset="0" />
                            <GradientStop Color="#FF0078D4" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <ui:SymbolIcon Symbol="Mic24" FontSize="36"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="WhisperHeim"
                           FontSize="36" FontWeight="ExtraBold"
                           Foreground="#FF1A1C1C"
                           HorizontalAlignment="Center" />
                <TextBlock Text="High-fidelity local transcription powered by neural networks."
                           FontSize="14" Foreground="#FF404752"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           Margin="0,8,0,0" />
                <TextBlock Text="Version 0.1.0"
                           FontSize="11"
                           Foreground="#FF717783"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
            </StackPanel>

            <!-- AI Models Section -->
            <Border Background="#FFF3F3F3" CornerRadius="12" Padding="0">
                <!-- Header -->
                <Border.Child>
                    <StackPanel>
                        <DockPanel Margin="24,20,24,16">
                            <TextBlock Text="AI MODELS"
                                       FontSize="11" FontWeight="Bold"
                                                                             VerticalAlignment="Center"
                                       DockPanel.Dock="Left" />
                        </DockPanel>

                        <!-- Model list -->
                        <ItemsControl x:Name="ModelList" Margin="8,0,8,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FFFFFFFF"
                                            CornerRadius="8"
                                            Padding="16,12"
                                            Margin="0,2,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Status icon -->
                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    CornerRadius="4"
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#19005FAA" />
                                                </Border.Background>
                                                <ui:SymbolIcon Symbol="Checkmark24"
                                                               Foreground="{Binding StatusBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                            </Border>

                                            <!-- Name and description -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="#FF1A1C1C" />
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="10"
                                                           Foreground="#FF404752"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>

                                            <!-- Size and status -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding SizeText}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Right"
                                                           Foreground="#FF1A1C1C" />
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="10"
                                                           Foreground="{Binding StatusBrush}"
                                                           FontWeight="Medium"
                                                           HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border.Child>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
