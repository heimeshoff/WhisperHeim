<UserControl x:Class="WhisperHeim.Views.Pages.VoiceLoopbackCapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel Margin="24">
        <TextBlock Text="Voice Cloning - System Audio"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />
        <TextBlock Text="Capture system audio (YouTube, podcasts, etc.) as a voice cloning reference."
                   Opacity="0.6" FontSize="12" Margin="0,0,0,16" TextWrapping="Wrap" />

        <!-- Warning about isolating audio -->
        <Border Background="#33FFA500" CornerRadius="4" Padding="12,8" Margin="0,0,0,16">
            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="Orange">
                <Run FontWeight="SemiBold">Tip:</Run>
                <Run>For best results, close other applications that play sound. Only the target voice should be audible during capture. Record at least 5 seconds of clear speech.</Run>
            </TextBlock>
        </Border>

        <!-- Output Device Selection -->
        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Output Device" FontWeight="Medium" />
                    <TextBlock Text="Select which audio output to capture from"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <ComboBox x:Name="DeviceCombo"
                      MinWidth="220"
                      DisplayMemberPath="DisplayName" />
        </ui:CardControl>

        <!-- Capture Controls -->
        <ui:CardControl Margin="0,8,0,8">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Capture" FontWeight="Medium" />
                    <TextBlock x:Name="DurationText"
                               Text="Duration: 00:00"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel Orientation="Horizontal">
                <ui:Button x:Name="StartButton"
                           Content="Start Capture"
                           Appearance="Primary"
                           Click="StartButton_Click"
                           Margin="0,0,8,0" />
                <ui:Button x:Name="StopButton"
                           Content="Stop"
                           Appearance="Danger"
                           Click="StopButton_Click"
                           IsEnabled="False" />
            </StackPanel>
        </ui:CardControl>

        <!-- Audio Level Meter -->
        <TextBlock Text="Audio Level"
                   FontSize="13"
                   FontWeight="Medium"
                   Margin="0,8,0,4" />
        <Grid Height="24" Margin="0,0,0,16">
            <Border Background="#20808080" CornerRadius="4" />
            <Border x:Name="LevelMeterFill"
                    Background="#4000CC00"
                    CornerRadius="4"
                    HorizontalAlignment="Left"
                    Width="0" />
            <TextBlock x:Name="LevelText"
                       Text="--"
                       FontSize="11"
                       Opacity="0.6"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Status Message -->
        <TextBlock x:Name="StatusText"
                   Text=""
                   Foreground="Orange"
                   FontSize="12"
                   Margin="0,0,0,8"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />

        <!-- Save Section -->
        <TextBlock Text="Save as Custom Voice"
                   FontSize="16"
                   FontWeight="Medium"
                   Margin="0,8,0,8" />

        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Voice Name" FontWeight="Medium" />
                    <TextBlock Text="Name for this voice (used in the TTS voice selector)"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <TextBox x:Name="VoiceNameBox"
                     MinWidth="220"
                     MaxLength="50" />
        </ui:CardControl>

        <ui:Button x:Name="SaveButton"
                   Content="Save Voice"
                   Appearance="Primary"
                   Click="SaveButton_Click"
                   IsEnabled="False"
                   Margin="0,8,0,0" />

        <TextBlock x:Name="SaveResultText"
                   Text=""
                   FontSize="12"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />
    </StackPanel>
</UserControl>
