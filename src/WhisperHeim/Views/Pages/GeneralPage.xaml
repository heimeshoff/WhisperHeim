<UserControl x:Class="WhisperHeim.Views.Pages.GeneralPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <StackPanel Margin="24">
        <TextBlock Text="General Settings"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Start minimized" FontWeight="Medium" />
                    <TextBlock Text="Launch WhisperHeim hidden in the system tray"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <CheckBox x:Name="StartMinimizedCheck"
                      IsChecked="{Binding StartMinimized, Mode=TwoWay}"
                      Checked="OnSettingChanged"
                      Unchecked="OnSettingChanged" />
        </ui:CardControl>

        <ui:CardControl Margin="0,0,0,8">
            <ui:CardControl.Header>
                <StackPanel>
                    <TextBlock Text="Launch at startup" FontWeight="Medium" />
                    <TextBlock Text="Automatically start with Windows"
                               Opacity="0.6" FontSize="12" />
                </StackPanel>
            </ui:CardControl.Header>
            <CheckBox x:Name="LaunchAtStartupCheck"
                      IsChecked="{Binding LaunchAtStartup, Mode=TwoWay}"
                      Checked="OnSettingChanged"
                      Unchecked="OnSettingChanged" />
        </ui:CardControl>
    </StackPanel>
</UserControl>
