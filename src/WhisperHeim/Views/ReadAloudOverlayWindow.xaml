<Window x:Class="WhisperHeim.Views.ReadAloudOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperHeim Read-Aloud Overlay"
        Width="48" Height="48"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        Opacity="0">

    <Window.Resources>
        <SineEase x:Key="PulseEasing" EasingMode="EaseInOut" />

        <!-- Thinking state: slow pulsing/breathing animation (model loading + generation) -->
        <Storyboard x:Key="ThinkingPulse" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="OverlayEllipse"
                Storyboard.TargetProperty="Opacity"
                From="0.5" To="1.0"
                Duration="0:0:0.8"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleX"
                From="0.88" To="1.04"
                Duration="0:0:0.8"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleY"
                From="0.88" To="1.04"
                Duration="0:0:0.8"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <!-- Rotate the icon for a spinning effect -->
            <DoubleAnimation
                Storyboard.TargetName="IconRotateTransform"
                Storyboard.TargetProperty="Angle"
                From="0" To="360"
                Duration="0:0:2.4"
                RepeatBehavior="Forever" />
        </Storyboard>

        <!-- Playing state: animated sound wave effect -->
        <Storyboard x:Key="PlayingPulse" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="OverlayEllipse"
                Storyboard.TargetProperty="Opacity"
                From="0.8" To="1.0"
                Duration="0:0:0.5"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleX"
                From="0.95" To="1.06"
                Duration="0:0:0.5"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleY"
                From="0.95" To="1.06"
                Duration="0:0:0.5"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <!-- Sound wave rings pulsing outward -->
            <DoubleAnimation
                Storyboard.TargetName="WaveRing1"
                Storyboard.TargetProperty="Opacity"
                From="0.6" To="0.0"
                Duration="0:0:1.0"
                RepeatBehavior="Forever" />
            <DoubleAnimation
                Storyboard.TargetName="WaveRingScale1"
                Storyboard.TargetProperty="ScaleX"
                From="1.0" To="1.8"
                Duration="0:0:1.0"
                RepeatBehavior="Forever" />
            <DoubleAnimation
                Storyboard.TargetName="WaveRingScale1"
                Storyboard.TargetProperty="ScaleY"
                From="1.0" To="1.8"
                Duration="0:0:1.0"
                RepeatBehavior="Forever" />
            <DoubleAnimation
                Storyboard.TargetName="WaveRing2"
                Storyboard.TargetProperty="Opacity"
                From="0.4" To="0.0"
                Duration="0:0:1.0"
                BeginTime="0:0:0.33"
                RepeatBehavior="Forever" />
            <DoubleAnimation
                Storyboard.TargetName="WaveRingScale2"
                Storyboard.TargetProperty="ScaleX"
                From="1.0" To="1.8"
                Duration="0:0:1.0"
                BeginTime="0:0:0.33"
                RepeatBehavior="Forever" />
            <DoubleAnimation
                Storyboard.TargetName="WaveRingScale2"
                Storyboard.TargetProperty="ScaleY"
                From="1.0" To="1.8"
                Duration="0:0:1.0"
                BeginTime="0:0:0.33"
                RepeatBehavior="Forever" />
        </Storyboard>

        <!-- Fade in -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                To="1.0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Fade out -->
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                To="0.0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </Window.Resources>

    <Grid>
        <!-- Sound wave rings (visible only during Playing state) -->
        <Ellipse x:Name="WaveRing1"
                 Stroke="#AA9B59B6" StrokeThickness="1.5"
                 Fill="Transparent"
                 Opacity="0"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="WaveRingScale1" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse x:Name="WaveRing2"
                 Stroke="#669B59B6" StrokeThickness="1"
                 Fill="Transparent"
                 Opacity="0"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="WaveRingScale2" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Main overlay circle -->
        <Ellipse x:Name="OverlayEllipse"
                 Fill="#CC2D2D2D"
                 StrokeThickness="2"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.Stroke>
                <SolidColorBrush x:Name="EllipseStrokeBrush" Color="#FF9B59B6" />
            </Ellipse.Stroke>
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Speaker icon using Segoe Fluent Icons (U+E767 = Volume3 / speaker with sound waves) -->
        <TextBlock x:Name="SpeakerIcon"
                   Text="&#xE767;"
                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                   FontSize="20"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5">
            <TextBlock.Foreground>
                <SolidColorBrush x:Name="IconBrush" Color="#FF9B59B6" />
            </TextBlock.Foreground>
            <TextBlock.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="IconScaleTransform" ScaleX="1" ScaleY="1" />
                    <RotateTransform x:Name="IconRotateTransform" Angle="0" />
                </TransformGroup>
            </TextBlock.RenderTransform>
        </TextBlock>
    </Grid>
</Window>
