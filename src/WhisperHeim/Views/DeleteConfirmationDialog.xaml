<Window x:Class="WhisperHeim.Views.DeleteConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Delete Recording"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <StackPanel Margin="32">
                <!-- Icon + Title -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="#20E81224" Margin="0,0,14,0">
                        <ui:SymbolIcon Symbol="Delete24" Foreground="#FFE81224"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="This action cannot be undone."
                                   FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Transcript name -->
                <Border Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,24">
                    <TextBlock x:Name="TranscriptNameText"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Padding="20,10"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontWeight="Medium"
                            Cursor="Hand" FontSize="13"
                            Click="Cancel_Click" />
                    <Button Padding="20,10" Cursor="Hand" FontSize="13"
                            Foreground="White" FontWeight="SemiBold"
                            BorderThickness="0"
                            Click="Delete_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Padding="{TemplateBinding Padding}"
                                        Background="#FFE81224">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        Delete
                    </Button>
                </StackPanel>
    </StackPanel>
</Window>
