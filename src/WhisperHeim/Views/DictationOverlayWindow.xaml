<Window x:Class="WhisperHeim.Views.DictationOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WhisperHeim Overlay"
        Width="48" Height="48"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        ResizeMode="NoResize"
        Opacity="0">

    <Window.Resources>
        <SineEase x:Key="PulseEasing" EasingMode="EaseInOut" />

        <!-- Gentle breathing/pulsing animation for listening state -->
        <Storyboard x:Key="ListeningPulse" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="OverlayEllipse"
                Storyboard.TargetProperty="Opacity"
                From="0.6" To="1.0"
                Duration="0:0:1.2"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleX"
                From="0.92" To="1.0"
                Duration="0:0:1.2"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleY"
                From="0.92" To="1.0"
                Duration="0:0:1.2"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
        </Storyboard>

        <!-- Faster animation for active speech -->
        <Storyboard x:Key="SpeechPulse" RepeatBehavior="Forever">
            <DoubleAnimation
                Storyboard.TargetName="OverlayEllipse"
                Storyboard.TargetProperty="Opacity"
                From="0.7" To="1.0"
                Duration="0:0:0.4"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleX"
                From="0.88" To="1.05"
                Duration="0:0:0.4"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
            <DoubleAnimation
                Storyboard.TargetName="ScaleTransform"
                Storyboard.TargetProperty="ScaleY"
                From="0.88" To="1.05"
                Duration="0:0:0.4"
                AutoReverse="True"
                EasingFunction="{StaticResource PulseEasing}" />
        </Storyboard>

        <!-- Fade in -->
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                To="1.0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Fade out -->
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation
                Storyboard.TargetProperty="Opacity"
                To="0.0"
                Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

    </Window.Resources>

    <Grid>
        <Ellipse x:Name="OverlayEllipse"
                 Fill="#CC2D2D2D"
                 Stroke="#FFEE3333"
                 StrokeThickness="2"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Microphone icon using Segoe Fluent Icons -->
        <TextBlock x:Name="MicIcon"
                   Text="&#xE720;"
                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                   FontSize="20"
                   Foreground="#FFEE3333"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5">
            <TextBlock.RenderTransform>
                <ScaleTransform x:Name="IconScaleTransform" ScaleX="1" ScaleY="1" />
            </TextBlock.RenderTransform>
        </TextBlock>
    </Grid>
</Window>
