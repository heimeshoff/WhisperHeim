<UserControl x:Class="WhisperHeim.Views.Controls.TranscriptionBottomBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <UserControl.Resources>
        <!-- Stage to display name converter -->
        <Style x:Key="QueueItemBorder" TargetType="Border">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Resources>

    <Border x:Name="RootBorder"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Collapsed bar (always visible) -->
            <Border Grid.Row="0"
                    Cursor="Hand"
                    MouseLeftButtonDown="CollapsedBar_Click"
                    Padding="12,6"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Status icon -->
                    <ui:SymbolIcon x:Name="StatusIcon"
                                   Grid.Column="0"
                                   Symbol="ArrowSync24"
                                   FontSize="14"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"
                                   Opacity="0.7" />

                    <!-- Status text -->
                    <TextBlock x:Name="StatusText"
                               Grid.Column="1"
                               Text="No active transcriptions"
                               FontSize="12"
                               VerticalAlignment="Center"
                               Opacity="0.7"
                               TextTrimming="CharacterEllipsis" />

                    <!-- Mini progress bar (visible when active) -->
                    <ProgressBar x:Name="MiniProgress"
                                 Grid.Column="2"
                                 Width="80"
                                 Height="4"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="0"
                                 Margin="8,0"
                                 VerticalAlignment="Center"
                                 Visibility="Collapsed" />

                    <!-- Expand/collapse chevron -->
                    <ui:SymbolIcon x:Name="ExpandChevron"
                                   Grid.Column="3"
                                   Symbol="ChevronUp24"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Opacity="0.5" />
                </Grid>
            </Border>

            <!-- Expanded panel -->
            <Border x:Name="ExpandedPanel"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    MaxHeight="250"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="12,8,12,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Transcription Queue"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />

                        <Button x:Name="ClearFinishedButton"
                                Grid.Column="1"
                                Content="Clear finished"
                                FontSize="11"
                                Padding="8,2"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="ClearFinished_Click"
                                Visibility="Collapsed" />
                    </Grid>

                    <!-- Queue items list -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="200"
                                  Margin="0,0,0,4">
                        <ItemsControl x:Name="QueueItemsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,6" Background="Transparent">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Status dot -->
                                            <Ellipse Grid.Column="0" Grid.Row="0"
                                                     Width="8" Height="8"
                                                     Margin="0,0,8,0"
                                                     VerticalAlignment="Center"
                                                     x:Name="StatusDot" />

                                            <!-- Title -->
                                            <TextBlock Grid.Column="1" Grid.Row="0"
                                                       Text="{Binding Title}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />

                                            <!-- Stage label -->
                                            <TextBlock Grid.Column="2" Grid.Row="0"
                                                       x:Name="StageLabel"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0"
                                                       Opacity="0.6" />

                                            <!-- Action button (remove/cancel/retry) -->
                                            <Button Grid.Column="3" Grid.Row="0"
                                                    x:Name="ActionButton"
                                                    FontSize="11"
                                                    Padding="6,2"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Visibility="Collapsed"
                                                    Click="ItemAction_Click"
                                                    Tag="{Binding}" />

                                            <!-- Progress bar (for active item) -->
                                            <ProgressBar Grid.Column="1" Grid.ColumnSpan="2"
                                                         Grid.Row="1"
                                                         x:Name="ItemProgress"
                                                         Height="3"
                                                         Minimum="0" Maximum="100"
                                                         Margin="0,4,0,0"
                                                         Visibility="Collapsed" />
                                        </Grid>
                                    </Border>

                                    <DataTemplate.Triggers>
                                        <!-- Queued: gray dot, "Queued" label, remove button -->
                                        <DataTrigger Binding="{Binding Stage}" Value="Queued">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="Gray" />
                                            <Setter TargetName="StageLabel" Property="Text" Value="Queued" />
                                            <Setter TargetName="ActionButton" Property="Content" Value="Remove" />
                                            <Setter TargetName="ActionButton" Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <!-- Loading: blue dot -->
                                        <DataTrigger Binding="{Binding Stage}" Value="Loading">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="#FF25abfe" />
                                            <Setter TargetName="StageLabel" Property="Text" Value="Loading..." />
                                            <Setter TargetName="ItemProgress" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="ItemProgress" Property="Value" Value="{Binding OverallPercent}" />
                                            <Setter TargetName="ActionButton" Property="Content" Value="Cancel" />
                                            <Setter TargetName="ActionButton" Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <!-- Diarizing: blue dot -->
                                        <DataTrigger Binding="{Binding Stage}" Value="Diarizing">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="#FF25abfe" />
                                            <Setter TargetName="StageLabel" Property="Text" Value="Diarizing..." />
                                            <Setter TargetName="ItemProgress" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="ItemProgress" Property="Value" Value="{Binding OverallPercent}" />
                                            <Setter TargetName="ActionButton" Property="Content" Value="Cancel" />
                                            <Setter TargetName="ActionButton" Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <!-- Transcribing: blue dot -->
                                        <DataTrigger Binding="{Binding Stage}" Value="Transcribing">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="#FF25abfe" />
                                            <Setter TargetName="StageLabel" Property="Text" Value="Transcribing..." />
                                            <Setter TargetName="ItemProgress" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="ItemProgress" Property="Value" Value="{Binding OverallPercent}" />
                                            <Setter TargetName="ActionButton" Property="Content" Value="Cancel" />
                                            <Setter TargetName="ActionButton" Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <!-- Assembling: blue dot -->
                                        <DataTrigger Binding="{Binding Stage}" Value="Assembling">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="#FF25abfe" />
                                            <Setter TargetName="StageLabel" Property="Text" Value="Assembling..." />
                                            <Setter TargetName="ItemProgress" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="ItemProgress" Property="Value" Value="{Binding OverallPercent}" />
                                            <Setter TargetName="ActionButton" Property="Content" Value="Cancel" />
                                            <Setter TargetName="ActionButton" Property="Visibility" Value="Visible" />
                                        </DataTrigger>

                                        <!-- Completed: green dot -->
                                        <DataTrigger Binding="{Binding Stage}" Value="Completed">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="#FF44CC44" />
                                            <Setter TargetName="StageLabel" Property="Text" Value="Completed" />
                                        </DataTrigger>

                                        <!-- Failed: red dot, retry button -->
                                        <DataTrigger Binding="{Binding Stage}" Value="Failed">
                                            <Setter TargetName="StatusDot" Property="Fill" Value="#FFCC4444" />
                                            <Setter TargetName="StageLabel" Property="Text" Value="Failed" />
                                            <Setter TargetName="ActionButton" Property="Content" Value="Retry" />
                                            <Setter TargetName="ActionButton" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
