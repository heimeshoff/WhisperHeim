<ui:FluentWindow x:Class="WhisperHeim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
        xmlns:controls="clr-namespace:WhisperHeim.Views.Controls"
        Title="WhisperHeim"
        Height="800" Width="1200"
        WindowStartupLocation="Manual"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <!-- Quiet Engine: Pill-shaped nav item style -->
        <Style x:Key="NavPillItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF005FAA" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="WhisperHeim" />

        <!-- Tray Icon -->
        <tray:NotifyIcon
            x:Name="TrayIcon"
            Grid.Row="0"
            FocusOnLeftClick="False"
            MenuOnRightClick="True"
            TooltipText="WhisperHeim"
            LeftClick="NotifyIcon_LeftClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem x:Name="CallRecordingMenuItem" Header="Start Call Recording" Click="TrayCallRecording_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Record24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Settings" Click="TraySettings_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Settings24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Exit" Click="TrayExit_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowExit20" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <!-- Main Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Nav panel -->
            <Grid x:Name="NavPanel" Grid.Column="0" Margin="12,0,4,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Branding header -->
                <StackPanel x:Name="BrandingHeader" Grid.Row="0" Margin="16,12,16,24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <!-- Logo icon (no background box, just the two-tone mic) -->
                        <Viewbox x:Name="BrandingLogo" Width="28" Height="28"
                                 Margin="0,0,10,0" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <!-- Microphone head (capsule) - Blue -->
                                <Path Fill="#FF25abfe"
                                      Data="M12,2 C9.79,2 8,3.79 8,6 L8,12 C8,14.21 9.79,16 12,16 C14.21,16 16,14.21 16,12 L16,6 C16,3.79 14.21,2 12,2 Z" />
                                <!-- Microphone stand (arc + stem + base) - Orange -->
                                <Path Fill="#FFff8b00"
                                      Data="M6,11 L6,12 C6,15.31 8.69,18 12,18 C15.31,18 18,15.31 18,12 L18,11 L16.5,11 L16.5,12 C16.5,14.49 14.49,16.5 12,16.5 C9.51,16.5 7.5,14.49 7.5,12 L7.5,11 Z M11.25,18.5 L11.25,21 L8.5,21 L8.5,22.5 L15.5,22.5 L15.5,21 L12.75,21 L12.75,18.5 Z" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock x:Name="BrandingTitle" Text="WhisperHeim"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Navigation items -->
                <ListBox x:Name="NavList"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem Tag="Dictation" IsSelected="True" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Mic24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelDictation" Text="DICTATION" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Templates" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Document24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelTemplates" Text="TEMPLATES" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Recordings" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DocumentText24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelRecordings" Text="RECORDINGS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Transcriptions" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelTranscriptions" Text="TRANSCRIPTIONS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="TextToSpeech" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ReadAloud24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelTextToSpeech" Text="TEXT TO SPEECH" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Settings" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelSettings" Text="SETTINGS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- About nav item pinned to bottom -->
                <ListBox x:Name="NavBottomList"
                         Grid.Row="2"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,8,0,0"
                         SelectionChanged="NavBottomList_SelectionChanged">
                    <ListBoxItem Tag="About" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Info24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelAbout" Text="ABOUT" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Grid>

            <!-- Sidebar collapse/expand chevron on right edge -->
            <Button x:Name="SidebarToggleButton"
                    Grid.Column="0"
                    Click="SidebarToggle_Click"
                    Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                    BorderThickness="0"
                    Cursor="Hand"
                    Width="16" Height="36"
                    Padding="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    ToolTip="Collapse sidebar"
                    Opacity="0.5">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="ChevronBd"
                                            Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="0,4,4,0"
                                            Padding="0"
                                            Width="{TemplateBinding Width}"
                                            Height="{TemplateBinding Height}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ChevronBd" Property="Background"
                                                    Value="{DynamicResource SubtleFillColorTertiaryBrush}" />
                                            <Setter Property="Opacity" Value="1.0" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
                <ui:SymbolIcon x:Name="SidebarToggleIcon" Symbol="ChevronLeft24" FontSize="12" />
            </Button>

            <!-- Page content area -->
            <ContentPresenter x:Name="PageContent"
                              Grid.Column="1" />
        </Grid>

        <!-- Transcription queue bottom bar (visible across all pages) -->
        <controls:TranscriptionBottomBar x:Name="TranscriptionBar"
                                          Grid.Row="2"
                                          Visibility="Collapsed" />
    </Grid>
</ui:FluentWindow>
