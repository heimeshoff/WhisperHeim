<ui:FluentWindow x:Class="WhisperHeim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
        Title="WhisperHeim"
        Height="800" Width="1200"
        WindowStartupLocation="Manual"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <!-- Quiet Engine: Pill-shaped nav item style -->
        <Style x:Key="NavPillItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FF005FAA" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="WhisperHeim" />

        <!-- Tray Icon -->
        <tray:NotifyIcon
            x:Name="TrayIcon"
            Grid.Row="0"
            FocusOnLeftClick="False"
            MenuOnRightClick="True"
            TooltipText="WhisperHeim"
            LeftClick="NotifyIcon_LeftClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem x:Name="CallRecordingMenuItem" Header="Start Call Recording" Click="TrayCallRecording_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Record24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Settings" Click="TraySettings_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Settings24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Exit" Click="TrayExit_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowExit20" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <!-- Main Layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Nav panel -->
            <Grid x:Name="NavPanel" Grid.Column="0" Margin="12,0,4,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Branding header -->
                <StackPanel Grid.Row="0" Margin="16,12,16,24">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <!-- Logo icon -->
                        <Border Width="32" Height="32"
                                CornerRadius="7" Margin="0,0,10,0"
                                Padding="2"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF25abfe" Offset="0" />
                                    <GradientStop Color="#FFff8b00" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="5">
                                <ui:SymbolIcon Symbol="Mic24" FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                    <ui:SymbolIcon.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF25abfe" Offset="0" />
                                            <GradientStop Color="#FFff8b00" Offset="1" />
                                        </LinearGradientBrush>
                                    </ui:SymbolIcon.Foreground>
                                </ui:SymbolIcon>
                            </Border>
                        </Border>
                        <TextBlock x:Name="BrandingTitle" Text="WhisperHeim"
                                   FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="BrandingSubtitle" Text="LOCAL-FIRST AI"
                               FontSize="9" FontWeight="Medium"
                               Margin="42,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Opacity="0.6" />
                </StackPanel>

                <!-- Navigation items -->
                <ListBox x:Name="NavList"
                         Grid.Row="1"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="NavList_SelectionChanged">
                    <ListBoxItem Tag="Dictation" IsSelected="True" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Mic24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelDictation" Text="DICTATION" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Templates" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Document24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelTemplates" Text="TEMPLATES" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Recordings" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="DocumentText24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelRecordings" Text="RECORDINGS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Transcriptions" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelTranscriptions" Text="TRANSCRIPTIONS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="TextToSpeech" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ReadAloud24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelTextToSpeech" Text="TEXT TO SPEECH" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="Settings" Style="{StaticResource NavPillItem}">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Settings24" Margin="0,0,10,0" FontSize="18" />
                            <TextBlock x:Name="NavLabelSettings" Text="SETTINGS" VerticalAlignment="Center"
                                       FontSize="11" FontWeight="Medium" />
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- Sidebar collapse/expand toggle -->
                <Button x:Name="SidebarToggleButton"
                        Grid.Row="2"
                        Click="SidebarToggle_Click"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Stretch"
                        Padding="16,8"
                        Margin="0,4,0,4"
                        ToolTip="Collapse sidebar">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon x:Name="SidebarToggleIcon" Symbol="PanelLeftContract24" FontSize="18" />
                        <TextBlock x:Name="SidebarToggleLabel" Text="COLLAPSE"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   FontSize="11" FontWeight="Medium" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Page content area -->
            <ContentPresenter x:Name="PageContent"
                              Grid.Column="1" />
        </Grid>
    </Grid>
</ui:FluentWindow>
