<ui:FluentWindow x:Class="WhisperHeim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:tray="clr-namespace:Wpf.Ui.Tray.Controls;assembly=Wpf.Ui.Tray"
        Title="WhisperHeim"
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <ui:TitleBar Grid.Row="0" Title="WhisperHeim" />

        <!-- Tray Icon -->
        <tray:NotifyIcon
            x:Name="TrayIcon"
            Grid.Row="0"
            FocusOnLeftClick="False"
            MenuOnRightClick="True"
            TooltipText="WhisperHeim"
            LeftClick="NotifyIcon_LeftClick">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem x:Name="CallRecordingMenuItem" Header="Start Call Recording" Click="TrayCallRecording_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Record24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Settings" Click="TraySettings_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Settings24" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <Separator />
                    <ui:MenuItem Header="Exit" Click="TrayExit_Click">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowExit20" />
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

        <!-- Settings Navigation -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Nav panel -->
            <ListBox x:Name="NavList"
                     Grid.Column="0"
                     Margin="8"
                     Background="Transparent"
                     BorderThickness="0"
                     SelectionChanged="NavList_SelectionChanged">
                <ListBoxItem Tag="General" IsSelected="True">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Settings24" Margin="0,0,8,0" />
                        <TextBlock Text="General" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="Dictation">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Mic24" Margin="0,0,8,0" />
                        <TextBlock Text="Dictation" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="Templates">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Document24" Margin="0,0,8,0" />
                        <TextBlock Text="Templates" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="TranscribeFiles">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ArrowDownload24" Margin="0,0,8,0" />
                        <TextBlock Text="Transcribe Files" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="Transcripts">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="DocumentText24" Margin="0,0,8,0" />
                        <TextBlock Text="Transcripts" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Tag="About">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Info24" Margin="0,0,8,0" />
                        <TextBlock Text="About" VerticalAlignment="Center" />
                    </StackPanel>
                </ListBoxItem>
            </ListBox>

            <!-- Page content area -->
            <ContentPresenter x:Name="PageContent"
                              Grid.Column="1" />
        </Grid>
    </Grid>
</ui:FluentWindow>
